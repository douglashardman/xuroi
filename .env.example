# Copy to .env.local for local dev (never commit secrets).

# API
XUROI_ADDR=:8080
DATABASE_URL=postgres://xuroi:xuroi_dev@localhost:5433/xuroi?sslmode=disable
MEDIA_DIR=../infra/uploads
SITE_URL=http://localhost:4321

# Email (optional — omit for log-only mailer in dev)
# XUROI_EMAIL_PROVIDER=ses
# XUROI_EMAIL_FROM=noreply@example.com
# XUROI_AWS_ACCESS_KEY_ID=
# XUROI_AWS_SECRET_ACCESS_KEY=
# XUROI_AWS_REGION=us-east-1

# LLM thread summaries (optional)
# XUROI_LLM_PROVIDER=openai
# XUROI_LLM_API_KEY=
# XUROI_LLM_MODEL=gpt-4o-mini