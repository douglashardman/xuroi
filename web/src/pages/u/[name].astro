---
export const prerender = false;

import ProfileAvatar from '../../components/ProfileAvatar.astro';
import Layout from '../../layouts/Layout.astro';
import { formatDate, formatLastSeen, getHome } from '../../lib/api';
import { getMe, getUserProfile, sessionFromCookieHeader } from '../../lib/server-api';
import { PAV_CLASSES, accentIndex, userURL } from '../../lib/theme';

const { name } = Astro.params;
const cookie = Astro.request.headers.get('cookie');
const session = sessionFromCookieHeader(cookie);
const [home, user] = await Promise.all([getHome(), getMe(session)]);

let profile;
try {
  profile = await getUserProfile(name!, session);
} catch {
  return Astro.redirect('/community');
}

const isOwnProfile = user && userURL(user.display_name) === `/u/${name}`;
const avIdx = accentIndex(profile.id);
---
<Layout title={profile.display_name} site={home.site} user={user}>
  <div class="profile-page">
    <section class="profile-identity">
      <ProfileAvatar
        name={profile.display_name}
        avatarUrl={profile.avatar_url}
        accentClass={PAV_CLASSES[avIdx]}
        editable={isOwnProfile}
      />
      <div class="profile-identity-body">
        <div class="profile-identity-top">
          <h1>{profile.display_name}</h1>
          {!isOwnProfile && user && (
            <div class="profile-actions" id="profile-actions">
              {profile.friendship === 'friends' ? (
                <button type="button" class="btn btn--sm btn--pending" disabled>Friends</button>
              ) : profile.friendship === 'pending_sent' ? (
                <button type="button" class="btn btn--sm btn--pending" disabled>Friend Request Pending</button>
              ) : profile.friendship === 'pending_received' ? (
                <button type="button" class="btn btn--sm btn--pink" id="profile-accept-friend-btn" data-request-id={profile.incoming_friend_request_id}>Accept friend request</button>
              ) : (
                <button type="button" class="btn btn--sm" id="profile-friend-btn" data-recipient-id={profile.id}>Add friend</button>
              )}
              {(profile.can_message !== false) && (
                <button type="button" class="btn btn--sm btn--pink profile-message-btn" id="profile-message-btn" data-recipient-id={profile.id}>
                  Message
                </button>
              )}
            </div>
          )}
        </div>
        {profile.bio && (
          <p class="profile-bio">{profile.bio}</p>
        )}
        <p class="profile-note">Karma comes from likes on your posts — liking your own posts doesn't count.</p>
      </div>
    </section>

    <div class="profile-stat-grid">
      <article class="profile-stat-card profile-stat-card--karma">
        <span class="profile-stat-label">Karma</span>
        <span class="profile-stat-value">{profile.karma.toLocaleString()}</span>
      </article>
      <article class="profile-stat-card">
        <span class="profile-stat-label">Posts</span>
        <span class="profile-stat-value">{profile.post_count.toLocaleString()}</span>
      </article>
      <article class="profile-stat-card">
        <span class="profile-stat-label">Joined</span>
        <span class="profile-stat-value profile-stat-value--sm">{formatDate(profile.joined_at)}</span>
      </article>
      {profile.last_active_at && (
        <article class="profile-stat-card">
          <span class="profile-stat-label">Last seen</span>
          <span class="profile-stat-value profile-stat-value--sm">{formatLastSeen(profile.last_active_at)}</span>
        </article>
      )}
    </div>

    {isOwnProfile && (
      <div class="profile-card-grid">
        <article class="profile-card profile-card--wide profile-card--pink">
          <header class="profile-card-head">
            <h2>About you</h2>
            <p class="profile-card-desc">Short intro shown on your public profile.</p>
          </header>
          <form id="profile-bio-form" class="profile-bio-form">
            <label>
              <span class="sr-only">Bio</span>
              <textarea name="bio" rows="3" maxlength="500" placeholder="A short intro for your profile…">{profile.bio ?? ''}</textarea>
            </label>
            <button type="submit" class="btn btn--sm">Save bio</button>
          </form>
        </article>

        <article class="profile-card profile-card--green">
          <header class="profile-card-head">
            <h2>Email notifications</h2>
            <p class="profile-card-desc">Thread reply and @mention emails.</p>
          </header>
          <a class="profile-card-link btn btn--sm" href="/settings/email">Manage preferences</a>
        </article>

        <article class="profile-card profile-card--yellow">
          <header class="profile-card-head">
            <h2>Online status</h2>
            <p class="profile-card-desc">Who can see you in the online list and last-seen here.</p>
          </header>
          <form id="online-privacy-form" class="profile-option-form">
            <label>
              <input type="checkbox" name="hide_online" checked={profile.hide_online === true} />
              Hide my online status from other members
            </label>
            <p class="profile-card-hint">Staff can always see who is online.</p>
            <button type="submit" class="btn btn--sm">Save visibility</button>
          </form>
        </article>

        <article class="profile-card profile-card--blue">
          <header class="profile-card-head">
            <h2>Message privacy</h2>
            <p class="profile-card-desc">Who can start a new conversation with you.</p>
          </header>
          <form id="dm-privacy-form" class="profile-option-form">
            <label>
              <input type="radio" name="dm_privacy" value="everyone" checked={user.dm_privacy !== 'friends_only' && user.dm_privacy !== 'off'} />
              Open — any member can message you
            </label>
            <label>
              <input type="radio" name="dm_privacy" value="friends_only" checked={user.dm_privacy === 'friends_only'} />
              Existing contacts only
            </label>
            <label>
              <input type="radio" name="dm_privacy" value="off" checked={user.dm_privacy === 'off'} />
              Off — no new messages
            </label>
            <button type="submit" class="btn btn--sm">Save privacy</button>
          </form>
        </article>

        <article class="profile-card profile-card--ink">
          <header class="profile-card-head">
            <h2>Account security</h2>
            <p class="profile-card-desc">
              {user.has_password ? 'Password set' : 'No password yet'}
              · {user.has_passkey ? 'Passkey added' : 'No passkey yet'}
            </p>
          </header>
          {!user.has_password && (
            <form id="set-password-form" class="profile-security-form">
              <label>
                Set a password
                <input type="password" name="password" minlength="8" maxlength="128" required autocomplete="new-password" />
              </label>
              <button type="submit" class="btn btn--sm btn--pink">Save password</button>
            </form>
          )}
          <button type="button" class="btn btn--sm" id="add-passkey-btn">
            {user.has_passkey ? 'Add another passkey' : 'Add passkey'}
          </button>
        </article>
      </div>
    )}
  </div>

  <script>
    import { initOwnProfileActions, initVisitorProfileActions } from '../../lib/profile-page';
    initVisitorProfileActions();
    initOwnProfileActions();
  </script>
</Layout>

<style>
  .profile-page {
    display: grid;
    gap: 14px;
    margin-top: 28px;
    margin-bottom: 36px;
  }

  .profile-identity {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    align-items: flex-start;
    padding: 18px 20px;
    border: var(--line);
    border-radius: 14px;
    background: var(--card);
    box-shadow: 4px 4px 0 var(--ink);
  }

  .profile-identity-body {
    flex: 1;
    min-width: min(100%, 240px);
  }

  .profile-identity-top {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 10px 16px;
  }

  .profile-identity h1 {
    margin: 0;
    font-size: 26px;
    line-height: 1.15;
  }

  .profile-bio {
    margin: 10px 0 0;
    font-size: 14px;
    line-height: 1.5;
    color: var(--ink);
    max-width: 60ch;
  }

  .profile-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .profile-note {
    margin: 8px 0 0;
    color: var(--faint);
    font-size: 12px;
    line-height: 1.4;
  }

  .profile-stat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(148px, 1fr));
    gap: 12px;
  }

  .profile-stat-card {
    display: grid;
    gap: 6px;
    padding: 14px 16px;
    border: var(--line);
    border-radius: 12px;
    background: var(--card);
    box-shadow: 3px 3px 0 var(--hair);
  }

  .profile-stat-card--karma {
    box-shadow: 3px 3px 0 var(--pink);
  }

  .profile-stat-label {
    font-family: Poppins, sans-serif;
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .profile-stat-value {
    font-family: Poppins, sans-serif;
    font-weight: 800;
    font-size: 22px;
    line-height: 1.1;
    color: var(--ink);
  }

  .profile-stat-card--karma .profile-stat-value {
    color: var(--pink);
  }

  .profile-stat-value--sm {
    font-size: 15px;
    font-weight: 700;
  }

  .profile-card-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .profile-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 16px 18px;
    border: var(--line);
    border-radius: 14px;
    background: var(--card);
  }

  .profile-card--wide {
    grid-column: 1 / -1;
  }

  .profile-card--pink { box-shadow: 4px 4px 0 var(--pink); }
  .profile-card--green { box-shadow: 4px 4px 0 var(--green); }
  .profile-card--yellow { box-shadow: 4px 4px 0 var(--yellow); }
  .profile-card--blue { box-shadow: 4px 4px 0 var(--blue); }
  .profile-card--ink { box-shadow: 4px 4px 0 var(--ink); }

  .profile-card-head h2 {
    margin: 0;
    font-size: 16px;
    font-weight: 700;
  }

  .profile-card-desc {
    margin: 4px 0 0;
    font-size: 13px;
    line-height: 1.4;
    color: var(--muted);
  }

  .profile-card-hint {
    margin: 0;
    font-size: 12px;
    color: var(--faint);
  }

  .profile-card-link {
    align-self: flex-start;
    margin-top: auto;
    text-decoration: none;
    text-align: center;
  }

  .profile-bio-form,
  .profile-option-form,
  .profile-security-form {
    display: grid;
    gap: 8px;
  }

  .profile-bio-form textarea {
    width: 100%;
    border: 2px solid var(--hair);
    border-radius: 10px;
    padding: 10px 12px;
    font: inherit;
    font-size: 14px;
    line-height: 1.45;
    background: var(--paper);
    resize: vertical;
    min-height: 72px;
    box-sizing: border-box;
  }

  .profile-option-form label {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    font-size: 13px;
    line-height: 1.4;
    cursor: pointer;
  }

  .profile-option-form input {
    margin-top: 2px;
    flex-shrink: 0;
  }

  .profile-security-form label {
    display: grid;
    gap: 6px;
    font-family: Poppins, sans-serif;
    font-weight: 600;
    font-size: 13px;
  }

  .profile-security-form input {
    border: 2px solid var(--hair);
    border-radius: 10px;
    padding: 9px 12px;
    font: inherit;
    background: var(--paper);
  }

  .btn--pending {
    cursor: not-allowed;
    opacity: 0.72;
    color: var(--muted);
    background: var(--paper);
    box-shadow: none;
    transform: none;
    pointer-events: none;
  }

  .btn--pending:hover {
    transform: none;
    box-shadow: none;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 640px) {
    .profile-page {
      margin-top: 20px;
    }

    .profile-identity {
      padding: 16px;
    }

    .profile-identity h1 {
      font-size: 22px;
    }

    .profile-identity-top {
      flex-direction: column;
      align-items: flex-start;
    }

    .profile-card-grid {
      grid-template-columns: 1fr;
    }

    .profile-card--wide {
      grid-column: auto;
    }
  }
</style>