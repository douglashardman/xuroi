---
export const prerender = false;

import ProfileAvatar from '../../components/ProfileAvatar.astro';
import Layout from '../../layouts/Layout.astro';
import { formatDate, formatLastSeen, getHome } from '../../lib/api';
import { getMe, getUserProfile, sessionFromCookieHeader } from '../../lib/server-api';
import { PAV_CLASSES, accentIndex, userURL } from '../../lib/theme';

const { name } = Astro.params;
const cookie = Astro.request.headers.get('cookie');
const session = sessionFromCookieHeader(cookie);
const [home, user] = await Promise.all([getHome(), getMe(session)]);

let profile;
try {
  profile = await getUserProfile(name!, session);
} catch {
  return Astro.redirect('/community');
}

const isOwnProfile = user && userURL(user.display_name) === `/u/${name}`;
const avIdx = accentIndex(profile.id);
---
<Layout title={profile.display_name} site={home.site} user={user}>
  <div class="profile-hero">
    <ProfileAvatar
      name={profile.display_name}
      avatarUrl={profile.avatar_url}
      accentClass={PAV_CLASSES[avIdx]}
      editable={isOwnProfile}
    />
    <div>
      <h1>{profile.display_name}</h1>
      <div class="profile-karma">{profile.karma.toLocaleString()} karma</div>
      <div class="profile-meta">
        {profile.post_count.toLocaleString()} posts · joined {formatDate(profile.joined_at)}
        {profile.last_active_at && (
          <span> · last seen {formatLastSeen(profile.last_active_at)}</span>
        )}
      </div>
      {profile.bio && !isOwnProfile && (
        <p class="profile-bio">{profile.bio}</p>
      )}
      {!isOwnProfile && user && (
        <div class="profile-actions" id="profile-actions">
          {profile.friendship === 'friends' ? (
            <button type="button" class="btn btn--sm btn--pending" disabled>Friends</button>
          ) : profile.friendship === 'pending_sent' ? (
            <button type="button" class="btn btn--sm btn--pending" disabled>Friend Request Pending</button>
          ) : profile.friendship === 'pending_received' ? (
            <button type="button" class="btn btn--sm btn--pink" id="profile-accept-friend-btn" data-request-id={profile.incoming_friend_request_id}>Accept friend request</button>
          ) : (
            <button type="button" class="btn btn--sm" id="profile-friend-btn" data-recipient-id={profile.id}>Add friend</button>
          )}
          {(profile.can_message !== false) && (
            <button type="button" class="btn btn--sm btn--pink profile-message-btn" id="profile-message-btn" data-recipient-id={profile.id}>
              Message
            </button>
          )}
        </div>
      )}
    </div>
  </div>
  <p class="profile-note">
    Karma comes from likes on your posts — liking your own posts doesn't count.
  </p>

  {isOwnProfile && (
    <section class="profile-bio-edit">
      <h2>About you</h2>
      <form id="profile-bio-form" class="profile-bio-form">
        <label>
          Bio
          <textarea name="bio" rows="4" maxlength="500" placeholder="A short intro for your profile…">{profile.bio ?? ''}</textarea>
        </label>
        <button type="submit" class="btn btn--sm">Save bio</button>
      </form>
    </section>
  )}

  {isOwnProfile && (
    <section class="profile-notifications">
      <h2>Email notifications</h2>
      <p class="profile-notifications-meta">
        Control thread reply and @mention emails.
        <a href="/settings/email">Manage email preferences →</a>
      </p>
    </section>
  )}

  {isOwnProfile && (
    <section class="profile-privacy">
      <h2>Online status</h2>
      <p class="profile-privacy-meta">Control whether others see you in the online list and last-seen on your profile.</p>
      <form id="online-privacy-form" class="profile-privacy-form">
        <label>
          <input type="checkbox" name="hide_online" checked={profile.hide_online === true} />
          Hide my online status from other members
        </label>
        <p class="profile-privacy-hint">Staff can always see who is online.</p>
        <button type="submit" class="btn btn--sm">Save visibility</button>
      </form>
    </section>
  )}

  {isOwnProfile && (
    <section class="profile-privacy">
      <h2>Message privacy</h2>
      <p class="profile-privacy-meta">Who can start a new conversation with you.</p>
      <form id="dm-privacy-form" class="profile-privacy-form">
        <label>
          <input type="radio" name="dm_privacy" value="everyone" checked={user.dm_privacy !== 'friends_only' && user.dm_privacy !== 'off'} />
          Open — any member can message you
        </label>
        <label>
          <input type="radio" name="dm_privacy" value="friends_only" checked={user.dm_privacy === 'friends_only'} />
          Existing contacts only — strangers can't start new chats
        </label>
        <label>
          <input type="radio" name="dm_privacy" value="off" checked={user.dm_privacy === 'off'} />
          Off — no new messages (you also can't send)
        </label>
        <button type="submit" class="btn btn--sm">Save privacy</button>
      </form>
    </section>
  )}

  {isOwnProfile && (
    <section class="profile-security">
      <h2>Account security</h2>
      <p class="profile-security-meta">
        {user.has_password ? 'Password set' : 'No password yet'}
        · {user.has_passkey ? 'Passkey added' : 'No passkey yet'}
      </p>
      {!user.has_password && (
        <form id="set-password-form" class="profile-security-form">
          <label>
            Set a password
            <input type="password" name="password" minlength="8" maxlength="128" required autocomplete="new-password" />
          </label>
          <button type="submit" class="btn btn--sm btn--pink">Save password</button>
        </form>
      )}
      <button type="button" class="btn btn--sm" id="add-passkey-btn">
        {user.has_passkey ? 'Add another passkey' : 'Add passkey'}
      </button>
    </section>
  )}

  <script>
    import { initOwnProfileActions, initVisitorProfileActions } from '../../lib/profile-page';
    initVisitorProfileActions();
    initOwnProfileActions();
  </script>
</Layout>

<style>
  .profile-hero {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    align-items: center;
    margin-top: 40px;
    padding: 28px;
    border: var(--line);
    border-radius: 18px;
    background: var(--card);
    box-shadow: 6px 6px 0 var(--pink);
  }
  .profile-hero h1 {
    margin: 0 0 6px;
    font-size: 32px;
  }
  .profile-karma {
    font-family: Poppins, sans-serif;
    font-weight: 700;
    font-size: 18px;
    color: var(--pink);
    margin-bottom: 6px;
  }
  .profile-meta {
    color: var(--muted);
    font-size: 14px;
  }
  .profile-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 14px;
  }
  .btn--pending {
    cursor: not-allowed;
    opacity: 0.72;
    color: var(--muted);
    background: var(--paper);
    box-shadow: none;
    transform: none;
    pointer-events: none;
  }
  .btn--pending:hover {
    transform: none;
    box-shadow: none;
  }
  .profile-notifications {
    margin-top: 28px;
    padding: 24px;
    border: var(--line);
    border-radius: 16px;
    background: var(--card);
    box-shadow: 4px 4px 0 var(--green);
  }
  .profile-notifications h2 {
    margin: 0 0 8px;
    font-size: 20px;
  }
  .profile-notifications-meta {
    margin: 0;
    color: var(--muted);
    font-size: 14px;
    line-height: 1.5;
  }
  .profile-notifications-meta a {
    color: var(--pink);
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
  }
  .profile-privacy {
    margin-top: 28px;
    padding: 24px;
    border: var(--line);
    border-radius: 16px;
    background: var(--card);
    box-shadow: 4px 4px 0 var(--yellow);
  }
  .profile-privacy h2 {
    margin: 0 0 8px;
    font-size: 20px;
  }
  .profile-privacy-meta {
    margin: 0 0 16px;
    color: var(--muted);
    font-size: 14px;
  }
  .profile-privacy-form {
    display: grid;
    gap: 10px;
    max-width: 420px;
  }
  .profile-privacy-form label {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 14px;
    line-height: 1.4;
    cursor: pointer;
  }
  .profile-privacy-form input {
    margin-top: 3px;
    flex-shrink: 0;
  }
  .profile-security {
    margin-top: 28px;
    padding: 24px;
    border: var(--line);
    border-radius: 16px;
    background: var(--card);
    box-shadow: 4px 4px 0 var(--blue);
  }
  .profile-security h2 {
    margin: 0 0 8px;
    font-size: 20px;
  }
  .profile-security-meta {
    margin: 0 0 16px;
    color: var(--muted);
    font-size: 14px;
  }
  .profile-security-form {
    display: grid;
    gap: 10px;
    margin-bottom: 14px;
    max-width: 320px;
  }
  .profile-security-form label {
    display: grid;
    gap: 6px;
    font-family: Poppins, sans-serif;
    font-weight: 600;
    font-size: 14px;
  }
  .profile-security-form input {
    border: 2px solid var(--hair);
    border-radius: 10px;
    padding: 10px 12px;
    font: inherit;
    background: var(--paper);
  }
  .profile-note {
    margin: 20px 0 0;
    color: var(--faint);
    font-size: 14px;
    max-width: 52ch;
  }
</style>