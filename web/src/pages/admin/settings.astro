---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { getHome } from '../../lib/api';
import { getAdminSiteSettings, getMe, sessionFromCookieHeader } from '../../lib/server-api';

const cookie = Astro.request.headers.get('cookie');
const session = sessionFromCookieHeader(cookie);
const user = await getMe(session);
if (!user?.is_admin) {
  return Astro.redirect('/community');
}

const [home, s] = await Promise.all([
  getHome(session),
  getAdminSiteSettings(session!),
]);
const reportReasons = s.moderation?.report_reasons ?? [];
const reservedNames = (s.reserved_display_names ?? []).join('\n');

const sections = [
  { id: 'settings-general', label: 'General' },
  { id: 'settings-staff', label: 'Staff' },
  { id: 'settings-posts', label: 'Posts' },
  { id: 'settings-guests', label: 'Guests' },
  { id: 'settings-email', label: 'Email' },
  { id: 'settings-intel', label: 'Summaries' },
  { id: 'settings-members', label: 'New members' },
  { id: 'settings-spam', label: 'Spam' },
  { id: 'settings-seo', label: 'SEO' },
  { id: 'settings-names', label: 'Reserved names' },
  { id: 'settings-reports', label: 'Reports' },
];
---
<Layout title="Site settings" site={home.site} user={user} noIndex={true} skipBanCheck={true} adminPage={true}>
  <div class="crumb">
    <a href="/community">Community</a>
    › <a href="/admin">Admin</a>
    › Settings
  </div>

  <div class="shead admin-settings-head">
    <div>
      <h2>Site settings</h2>
      <span class="lab">Policy and configuration — persisted to site.json</span>
    </div>
    <span class="admin-settings-dirty" id="settings-dirty" hidden>Unsaved changes</span>
  </div>

  <div class="admin-settings-layout">
    <nav class="admin-settings-nav" aria-label="Settings sections">
      {sections.map((sec) => (
        <a class="admin-settings-nav-link" href={`#${sec.id}`} data-settings-jump>{sec.label}</a>
      ))}
    </nav>

    <form id="settings-form" class="admin-settings-main">
      <script type="application/json" id="settings-admin-base" set:html={JSON.stringify(s.admin ?? {})}></script>

      <section class="admin-settings-card" id="settings-general">
        <header class="admin-settings-card-head">
          <h3>General</h3>
          <p>Public site identity shown across the community.</p>
        </header>
        <div class="admin-settings-grid">
          <label class="admin-settings-field">
            <span>Site name</span>
            <input class="admin-settings-input" type="text" id="set-name" value={s.name ?? ''} required />
          </label>
          <label class="admin-settings-field admin-settings-field--wide">
            <span>Tagline</span>
            <input class="admin-settings-input" type="text" id="set-tagline" value={s.tagline ?? ''} />
          </label>
        </div>
      </section>

      <section class="admin-settings-card" id="settings-staff">
        <header class="admin-settings-card-head">
          <h3>Staff access</h3>
          <p>Owner admin emails stay in site.json for safety — edit the file directly to change owners.</p>
        </header>
        <div class="admin-settings-grid">
          <label class="admin-settings-field admin-settings-field--wide">
            <span>Moderator emails</span>
            <input class="admin-settings-input" type="text" id="set-mod-emails" value={Array.isArray(s.admin?.moderator_emails) ? s.admin.moderator_emails.join(', ') : ''} placeholder="mod@example.com, other@example.com" />
            <span class="admin-settings-hint">Comma-separated. Grants moderator permissions on sign-in.</span>
          </label>
          <label class="admin-settings-field admin-settings-field--wide">
            <span>Permanent-ban moderator emails</span>
            <input class="admin-settings-input" type="text" id="set-perm-ban-emails" value={Array.isArray(s.admin?.perm_ban_moderator_emails) ? s.admin.perm_ban_moderator_emails.join(', ') : ''} />
            <span class="admin-settings-hint">May issue permanent bans in addition to admins.</span>
          </label>
        </div>
      </section>

      <section class="admin-settings-card" id="settings-posts">
        <header class="admin-settings-card-head">
          <h3>Posts</h3>
          <p>Member editing and staff delete policy.</p>
        </header>
        <div class="admin-settings-grid">
          <label class="admin-settings-check">
            <input type="checkbox" id="set-edit-enabled" checked={s.posts?.edit_enabled !== false} />
            <span>Members can edit own posts</span>
          </label>
          <label class="admin-settings-field">
            <span>Edit window (minutes)</span>
            <input class="admin-settings-input" type="number" id="set-edit-window" min="1" value={s.posts?.edit_window_minutes ?? 30} />
          </label>
          <label class="admin-settings-check admin-settings-field--wide">
            <input type="checkbox" id="set-delete-enabled" checked={s.posts?.delete_enabled === true} />
            <span>Staff can delete replies (site-wide)</span>
          </label>
        </div>
      </section>

      <section class="admin-settings-card" id="settings-guests">
        <header class="admin-settings-card-head">
          <h3>Guests</h3>
          <p>Controls for signed-out visitors.</p>
        </header>
        <div class="admin-settings-grid">
          <label class="admin-settings-check">
            <input type="checkbox" id="set-guest-readonly" checked={s.guests?.read_only !== false} />
            <span>Guests read-only (cannot post)</span>
          </label>
          <label class="admin-settings-check">
            <input type="checkbox" id="set-guest-attach" checked={s.guests?.can_attach === true} />
            <span>Guests can attach files</span>
          </label>
        </div>
      </section>

      <section class="admin-settings-card" id="settings-email">
        <header class="admin-settings-card-head">
          <h3>Email</h3>
          <p>Notification sender identity. Provider credentials live in environment variables.</p>
        </header>
        <div class="admin-settings-grid">
          <label class="admin-settings-check admin-settings-field--wide">
            <input type="checkbox" id="set-email-enabled" checked={s.email?.enabled !== false} />
            <span>Email notifications enabled</span>
          </label>
          <label class="admin-settings-field">
            <span>From address</span>
            <input class="admin-settings-input" type="email" id="set-email-from" value={s.email?.from_address ?? ''} />
          </label>
          <label class="admin-settings-field">
            <span>From name</span>
            <input class="admin-settings-input" type="text" id="set-email-from-name" value={s.email?.from_name ?? ''} />
          </label>
          <label class="admin-settings-field">
            <span>Reply-to</span>
            <input class="admin-settings-input" type="email" id="set-email-reply" value={s.email?.reply_to ?? ''} />
          </label>
          <label class="admin-settings-field">
            <span>Thread reply digest delay (minutes)</span>
            <input class="admin-settings-input" type="number" id="set-email-digest" min="1" value={s.email?.digest_delay_minutes ?? 5} />
          </label>
        </div>
      </section>

      <section class="admin-settings-card" id="settings-intel">
        <header class="admin-settings-card-head">
          <h3>Thread summaries</h3>
          <p>Heuristic summaries on thread pages and machine exports.</p>
        </header>
        <div class="admin-settings-grid">
          <label class="admin-settings-check">
            <input type="checkbox" id="set-intel-enabled" checked={s.intelligence?.enabled !== false} />
            <span>Intelligence summaries on threads</span>
          </label>
          <label class="admin-settings-field">
            <span>Summary label</span>
            <input class="admin-settings-input" type="text" id="set-intel-label" value={s.intelligence?.summary_label ?? 'TL;DR'} />
          </label>
        </div>
      </section>

      <section class="admin-settings-card" id="settings-members">
        <header class="admin-settings-card-head">
          <h3>New members</h3>
          <p>Anti-abuse restrictions for recently registered accounts.</p>
        </header>
        <div class="admin-settings-grid">
          <label class="admin-settings-field">
            <span>Link restriction (hours)</span>
            <input class="admin-settings-input" type="number" id="set-link-hours" min="0" value={s.new_users?.restrict_links_hours ?? 24} />
          </label>
          <label class="admin-settings-field">
            <span>DM restriction (hours)</span>
            <input class="admin-settings-input" type="number" id="set-dm-hours" min="0" value={s.new_users?.restrict_dm_hours ?? 72} />
          </label>
        </div>
      </section>

      <section class="admin-settings-card" id="settings-spam">
        <header class="admin-settings-card-head">
          <h3>Spam filter</h3>
          <p>Heuristic scoring for new accounts and suspicious posts.</p>
        </header>
        <div class="admin-settings-grid">
          <label class="admin-settings-check">
            <input type="checkbox" id="set-spam-enabled" checked={s.spam?.enabled !== false} />
            <span>Enable spam scoring</span>
          </label>
          <label class="admin-settings-check">
            <input type="checkbox" id="set-spam-hold" checked={s.spam?.hold_for_moderation !== false} />
            <span>Hold suspicious posts for approval (vs block)</span>
          </label>
          <label class="admin-settings-field">
            <span>Score threshold</span>
            <input class="admin-settings-input" type="number" id="set-spam-threshold" min="1" value={s.spam?.score_threshold ?? 6} />
          </label>
          <label class="admin-settings-field">
            <span>Max links (new accounts)</span>
            <input class="admin-settings-input" type="number" id="set-spam-max-links" min="0" value={s.spam?.max_links_new_user ?? 2} />
          </label>
          <label class="admin-settings-field">
            <span>New account window (hours)</span>
            <input class="admin-settings-input" type="number" id="set-spam-new-hours" min="1" value={s.spam?.new_account_hours ?? 48} />
          </label>
        </div>
      </section>

      <section class="admin-settings-card" id="settings-seo">
        <header class="admin-settings-card-head">
          <h3>SEO</h3>
          <p>Search-engine signals for user-generated links.</p>
        </header>
        <div class="admin-settings-grid">
          <label class="admin-settings-check admin-settings-field--wide">
            <input type="checkbox" id="set-seo-nofollow" checked={s.seo?.nofollow_user_links !== false} />
            <span>Add <code>nofollow</code> to external links in posts</span>
          </label>
        </div>
      </section>

      <section class="admin-settings-card" id="settings-names">
        <header class="admin-settings-card-head">
          <h3>Reserved display names</h3>
          <p>Blocked at registration (case-insensitive). Built-in staff names are always reserved.</p>
        </header>
        <div class="admin-settings-grid">
          <label class="admin-settings-field admin-settings-field--wide">
            <span>Reserved names</span>
            <textarea class="admin-settings-input admin-settings-textarea" id="set-reserved-names" rows="6" placeholder="admin&#10;moderator&#10;puttertalk">{reservedNames}</textarea>
            <span class="admin-settings-hint">One name per line.</span>
          </label>
        </div>
      </section>

      <section class="admin-settings-card" id="settings-reports">
        <header class="admin-settings-card-head">
          <h3>Report reasons</h3>
          <p>Shown in the report picker. Keep IDs stable — edit labels unless you know what you're doing.</p>
        </header>
        <div id="report-reasons" class="admin-settings-reasons">
          {reportReasons.map((r) => (
            <div class="report-reason-row">
              <input type="text" class="admin-settings-input rr-id" value={r.id} placeholder="id" />
              <input type="text" class="admin-settings-input rr-label" value={r.label} placeholder="Label" />
              <label class="admin-settings-check rr-detail">
                <input type="checkbox" class="rr-allow-detail" checked={r.allow_detail === true} />
                <span>Detail</span>
              </label>
              <button type="button" class="btn btn--sm btn--ghost rr-remove" aria-label="Remove reason">×</button>
            </div>
          ))}
        </div>
        <button type="button" class="btn btn--sm btn--ghost" id="add-report-reason">Add reason</button>
      </section>

      <p class="admin-settings-error form-error" id="set-error" hidden></p>
    </form>
  </div>

  <div class="admin-settings-savebar">
    <div class="admin-settings-savebar-inner wrap">
      <p class="admin-settings-savebar-note">Changes apply immediately across the running engine.</p>
      <button type="submit" form="settings-form" class="btn btn--pink" id="settings-save-btn">Save all settings</button>
    </div>
  </div>
</Layout>

<script>
  import { initAdminSettingsForm } from '../../lib/admin-settings';
  initAdminSettingsForm();
</script>