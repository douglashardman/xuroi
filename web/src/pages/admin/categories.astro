---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { getHome } from '../../lib/api';
import { getAccessLevels, getAdminCategories, getMe, sessionFromCookieHeader } from '../../lib/server-api';

const cookie = Astro.request.headers.get('cookie');
const session = sessionFromCookieHeader(cookie);
const user = await getMe(session);
if (!user?.is_admin) {
  return Astro.redirect('/community');
}

const [home, tree, accessCatalog] = await Promise.all([
  getHome(),
  getAdminCategories(session!),
  getAccessLevels(session!),
]);
const groups = tree.groups ?? [];
const forumCount = (tree.categories ?? []).length;
const accessLevels = accessCatalog.levels ?? [];
---
<Layout title="Categories" site={home.site} user={user} noIndex={true} skipBanCheck={true} adminPage={true}>
  <div class="crumb">
    <a href="/community">Community</a>
    › <a href="/admin">Admin</a>
    › Categories
  </div>

  <div class="shead" style="margin-top:8px">
    <h2>Categories</h2>
    <span class="lab">{groups.length} sections · {forumCount} forums</span>
    <button type="button" class="btn btn--sm btn--pink" id="add-group-btn">Add section</button>
  </div>

  <p id="reorder-status" class="admin-reorder-hint">
    Drag sections or forums to reorder · assign multiple access groups per forum ·
    <a href="/admin/users">manage member groups on Users</a>
  </p>

  <div class="admin-cat-list" id="cat-tree">
    {groups.length === 0 ? (
      <p class="mod-empty">No categories yet. Add a section to get started.</p>
    ) : (
      groups.map((group) => {
        const groupHasThreads = group.forums.some((f) => f.thread_count > 0);
        return (
        <section class="admin-cat-group" data-group-id={group.id}>
          <div class="admin-cat-group-head admin-bar">
            <div class="admin-cat-group-title">
              <span class="drag-handle drag-handle--group" role="button" tabindex="0" aria-label={`Drag section ${group.name}`} title="Drag to reorder section">⠿</span>
              <div>
                <strong>{group.name}</strong>
                <span class="lab">{group.forums.length} forums</span>
              </div>
            </div>
            <div class="admin-cat-actions admin-actions">
              <button
                type="button"
                class="btn btn--sm btn--ghost"
                data-edit-group={group.id}
                data-name={group.name}
                data-slug={group.slug}
                data-description={group.description}
                data-sort={group.sort_order}
              >Edit section</button>
              <button
                type="button"
                class="btn btn--sm btn--ghost"
                data-add-forum={group.id}
                data-group-name={group.name}
              >Add forum</button>
              <button
                type="button"
                class="btn btn--sm btn--ghost btn--danger"
                data-delete-group={group.id}
                data-name={group.name}
                data-forum-count={group.forums.length}
                data-has-threads={groupHasThreads ? '1' : '0'}
                disabled={groupHasThreads}
                title={groupHasThreads ? 'Move or delete threads in child forums first' : group.forums.length > 0 ? 'Deletes section and empty forums' : 'Delete empty section'}
              >Delete section</button>
            </div>
          </div>
          <ul class="admin-cat-forums" data-group-id={group.id}>
            {group.forums.map((forum) => (
              <li class="admin-cat-forum" data-forum-id={forum.id}>
                <span class="drag-handle" role="button" tabindex="0" aria-label={`Drag forum ${forum.name}`} title="Drag to reorder">⠿</span>
                <div class="admin-cat-forum-main">
                  <a href={forum.url}><strong>{forum.name}</strong></a>
                  <span class="lab">/{forum.slug}</span>
                  {(() => {
                    const levels = (forum.access_levels?.length ? forum.access_levels : (forum.access_level && forum.access_level !== 'public' ? [forum.access_level] : []));
                    if (levels.length === 0) return null;
                    return (
                      <>
                        {levels.map((level) => (
                          <span class="access-badge">{accessLevels.find((l) => l.id === level)?.label ?? level}</span>
                        ))}
                        <span class={`vis-badge ${forum.list_public ? 'vis-badge--listed' : 'vis-badge--hidden'}`}>
                          {forum.list_public ? 'Listed' : 'Hidden'}
                        </span>
                      </>
                    );
                  })()}
                  {forum.description && <p>{forum.description}</p>}
                  <span class="lab">{forum.thread_count} threads · {forum.post_count} posts</span>
                </div>
                <div class="admin-cat-actions admin-actions">
                  <button
                    type="button"
                    class="btn btn--sm btn--ghost"
                    data-edit-forum={forum.id}
                    data-name={forum.name}
                    data-slug={forum.slug}
                    data-description={forum.description}
                    data-sort={forum.sort_order}
                    data-parent={group.id}
                    data-access-levels={JSON.stringify(forum.access_levels?.length ? forum.access_levels : (forum.access_level && forum.access_level !== 'public' ? [forum.access_level] : []))}
                    data-list-public={forum.list_public ? '1' : '0'}
                  >Edit</button>
                  <button
                    type="button"
                    class="btn btn--sm btn--ghost btn--danger"
                    data-delete={forum.id}
                    data-name={forum.name}
                    disabled={forum.thread_count > 0}
                    title={forum.thread_count > 0 ? 'Move or delete threads first' : 'Delete empty forum'}
                  >Delete</button>
                </div>
              </li>
            ))}
          </ul>
        </section>
        );
      })
    )}
  </div>

  <dialog id="cat-dialog" class="admin-dialog">
    <form method="dialog" id="cat-form">
      <h3 id="cat-dialog-title">Category</h3>
      <input type="hidden" name="id" id="cat-id" />
      <input type="hidden" name="parent_id" id="cat-parent-id" />
      <label>
        Name
        <input type="text" name="name" id="cat-name" required />
      </label>
      <label>
        Slug
        <input type="text" name="slug" id="cat-slug" required pattern="[a-z0-9-]+" />
      </label>
      <label>
        Description
        <textarea name="description" id="cat-description" rows="3"></textarea>
      </label>
      <label>
        Sort order
        <input type="number" name="sort_order" id="cat-sort" min="1" value="1" />
      </label>
      <fieldset id="cat-access-wrap" class="cat-access-fieldset">
        <legend>Access groups</legend>
        <p class="check-hint">Members need any one of the selected groups. Leave all unchecked for public access.</p>
        <div class="cat-access-levels" id="cat-access-levels">
          {accessLevels.filter((level) => level.id !== 'public').map((level) => (
            <label class="check-label cat-access-option">
              <input type="checkbox" name="access_level" value={level.id} />
              {level.label}
            </label>
          ))}
        </div>
      </fieldset>
      <label id="cat-list-public-wrap" class="check-label">
        <input type="checkbox" id="cat-list-public" />
        Show on community index
        <span class="check-hint">When checked, members without access see a locked row. When unchecked, the forum is hidden until they qualify.</span>
      </label>
      <div class="admin-dialog-actions">
        <button type="button" class="btn btn--ghost" id="cat-cancel">Cancel</button>
        <button type="submit" class="btn btn--pink" id="cat-save">Save</button>
      </div>
    </form>
  </dialog>
</Layout>

<script>
  import { initAdminCategoryDrag } from '../../lib/admin-category-drag';

  const dialog = document.getElementById('cat-dialog') as HTMLDialogElement;
  const form = document.getElementById('cat-form') as HTMLFormElement;
  const titleEl = document.getElementById('cat-dialog-title')!;
  const idEl = document.getElementById('cat-id') as HTMLInputElement;
  const parentEl = document.getElementById('cat-parent-id') as HTMLInputElement;
  const nameEl = document.getElementById('cat-name') as HTMLInputElement;
  const slugEl = document.getElementById('cat-slug') as HTMLInputElement;
  const descEl = document.getElementById('cat-description') as HTMLTextAreaElement;
  const sortEl = document.getElementById('cat-sort') as HTMLInputElement;
  const accessWrap = document.getElementById('cat-access-wrap')!;
  const accessInputs = () => Array.from(document.querySelectorAll<HTMLInputElement>('#cat-access-levels input[name="access_level"]'));
  const listPublicWrap = document.getElementById('cat-list-public-wrap')!;
  const listPublicEl = document.getElementById('cat-list-public') as HTMLInputElement;
  let mode: 'create' | 'edit' = 'create';
  let listPublicTouched = false;

  function selectedAccessLevels(): string[] {
    const checked = accessInputs().filter((el) => el.checked).map((el) => el.value);
    return checked.length ? checked : ['public'];
  }

  function defaultListPublic(levels: string[]) {
    return !levels.some((level) => level === 'staff' || level === 'admin');
  }

  function setAccessLevels(levels: string[]) {
    const active = new Set(levels.filter((level) => level !== 'public'));
    accessInputs().forEach((input) => {
      input.checked = active.has(input.value);
    });
  }

  function syncListPublicUI() {
    const levels = selectedAccessLevels();
    const restricted = !!parentEl.value && !levels.every((level) => level === 'public');
    listPublicWrap.style.display = restricted ? '' : 'none';
    if (restricted && !listPublicTouched) {
      listPublicEl.checked = defaultListPublic(levels);
    }
  }

  function slugify(value: string) {
    return value.trim().toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
  }

  function openDialog(opts: {
    mode: 'create' | 'edit';
    kind: 'group' | 'forum';
    id?: string;
    parentId?: string;
    name?: string;
    slug?: string;
    description?: string;
    sortOrder?: number;
    accessLevels?: string[];
    listPublic?: boolean;
  }) {
    mode = opts.mode;
    listPublicTouched = opts.mode === 'edit';
    idEl.value = opts.id ?? '';
    parentEl.value = opts.parentId ?? '';
    nameEl.value = opts.name ?? '';
    slugEl.value = opts.slug ?? '';
    descEl.value = opts.description ?? '';
    sortEl.value = String(opts.sortOrder ?? 1);
    accessWrap.style.display = opts.kind === 'forum' ? '' : 'none';
    setAccessLevels(opts.accessLevels ?? []);
    listPublicEl.checked = opts.listPublic ?? defaultListPublic(selectedAccessLevels());
    syncListPublicUI();
    titleEl.textContent =
      opts.mode === 'create'
        ? opts.kind === 'group'
          ? 'Add section'
          : 'Add forum'
        : opts.kind === 'group'
          ? 'Edit section'
          : 'Edit forum';
    dialog.showModal();
  }

  nameEl.addEventListener('input', () => {
    if (mode === 'create' && !slugEl.dataset.touched) {
      slugEl.value = slugify(nameEl.value);
    }
  });
  slugEl.addEventListener('input', () => {
    slugEl.dataset.touched = '1';
  });

  accessInputs().forEach((input) => {
    input.addEventListener('change', () => {
      listPublicTouched = false;
      syncListPublicUI();
    });
  });
  listPublicEl.addEventListener('change', () => {
    listPublicTouched = true;
  });

  document.getElementById('add-group-btn')?.addEventListener('click', () => {
    slugEl.dataset.touched = '';
    listPublicTouched = false;
    openDialog({ mode: 'create', kind: 'group', sortOrder: document.querySelectorAll('.admin-cat-group').length + 1 });
  });

  document.getElementById('cat-tree')?.addEventListener('click', (e) => {
    const t = e.target as HTMLElement;
    const editGroup = t.closest('[data-edit-group]') as HTMLElement | null;
    if (editGroup) {
      openDialog({
        mode: 'edit',
        kind: 'group',
        id: editGroup.dataset.editGroup,
        name: editGroup.dataset.name,
        slug: editGroup.dataset.slug,
        description: editGroup.dataset.description,
        sortOrder: Number(editGroup.dataset.sort),
      });
      return;
    }
    const addForum = t.closest('[data-add-forum]') as HTMLElement | null;
    if (addForum) {
      slugEl.dataset.touched = '';
      listPublicTouched = false;
      const groupEl = addForum.closest('.admin-cat-group');
      const count = groupEl?.querySelectorAll('.admin-cat-forum').length ?? 0;
      openDialog({
        mode: 'create',
        kind: 'forum',
        parentId: addForum.dataset.addForum,
        sortOrder: count + 1,
      });
      return;
    }
    const editForum = t.closest('[data-edit-forum]') as HTMLElement | null;
    if (editForum) {
      openDialog({
        mode: 'edit',
        kind: 'forum',
        id: editForum.dataset.editForum,
        parentId: editForum.dataset.parent,
        name: editForum.dataset.name,
        slug: editForum.dataset.slug,
        description: editForum.dataset.description,
        sortOrder: Number(editForum.dataset.sort),
        accessLevels: JSON.parse(editForum.dataset.accessLevels ?? '[]') as string[],
        listPublic: editForum.dataset.listPublic === '1',
      });
      return;
    }
    const delGroup = t.closest('[data-delete-group]') as HTMLButtonElement | null;
    if (delGroup && !delGroup.disabled) {
      const id = delGroup.dataset.deleteGroup;
      const name = delGroup.dataset.name;
      const forumCount = Number(delGroup.dataset.forumCount ?? 0);
      if (!id) return;
      const msg = forumCount > 0
        ? `Delete section "${name}" and ${forumCount} empty forum${forumCount === 1 ? '' : 's'}? This cannot be undone.`
        : `Delete section "${name}"? This cannot be undone.`;
      if (!confirm(msg)) return;
      const cascade = forumCount > 0 ? '?cascade=true' : '';
      fetch(`/api/admin/categories/${id}${cascade}`, { method: 'DELETE' })
        .then((res) => res.json().then((body) => ({ res, body })))
        .then(({ res, body }) => {
          if (!res.ok) throw new Error(body.error ?? 'Delete failed');
          location.reload();
        })
        .catch((err) => alert(err.message));
      return;
    }
    const del = t.closest('[data-delete]') as HTMLElement | null;
    if (del && !del.hasAttribute('disabled')) {
      const id = del.dataset.delete;
      const name = del.dataset.name;
      if (!id || !confirm(`Delete forum "${name}"? This cannot be undone.`)) return;
      fetch(`/api/admin/categories/${id}`, { method: 'DELETE' })
        .then((res) => res.json().then((body) => ({ res, body })))
        .then(({ res, body }) => {
          if (!res.ok) throw new Error(body.error ?? 'Delete failed');
          location.reload();
        })
        .catch((err) => alert(err.message));
    }
  });

  document.getElementById('cat-cancel')?.addEventListener('click', () => dialog.close());

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const levels = parentEl.value ? selectedAccessLevels() : ['public'];
    const payload = {
      name: nameEl.value.trim(),
      slug: slugEl.value.trim(),
      description: descEl.value.trim(),
      sort_order: Number(sortEl.value) || 1,
      parent_id: parentEl.value || null,
      access_levels: levels,
      list_public: parentEl.value && !levels.every((level) => level === 'public') ? listPublicEl.checked : true,
    };
    const id = idEl.value;
    const url = id ? `/api/admin/categories/${id}` : '/api/admin/categories';
    const method = id ? 'PATCH' : 'POST';
    try {
      const res = await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const body = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(body.error ?? 'Save failed');
      location.reload();
    } catch (err) {
      alert(err instanceof Error ? err.message : 'Save failed');
    }
  });

  initAdminCategoryDrag();
</script>

<style>
  .admin-cat-list {
    display: grid;
    gap: 20px;
    margin-top: 16px;
  }

  .admin-cat-forums {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .admin-reorder-hint {
    margin: 0 0 12px;
    font-size: 0.9rem;
    color: var(--muted);
  }
  .admin-reorder-hint--busy { color: var(--ink); font-weight: 600; }
  .admin-reorder-hint--ok { color: #15803d; font-weight: 600; }
  .admin-reorder-hint--error { color: #b91c1c; font-weight: 600; }

  .drag-handle {
    flex: none;
    align-self: center;
    width: 28px;
    height: 28px;
    display: grid;
    place-items: center;
    border: 2px solid var(--hair);
    border-radius: 8px;
    background: var(--mist);
    color: var(--muted);
    font-size: 14px;
    line-height: 1;
    cursor: grab;
    touch-action: none;
    user-select: none;
    -webkit-user-select: none;
  }
  .drag-handle:active,
  .admin-cat-forum.dragging .drag-handle,
  .admin-cat-group.dragging .drag-handle--group {
    cursor: grabbing;
  }
  .drag-handle--group {
    background: transparent;
    border-color: rgba(255, 255, 255, 0.35);
    color: var(--paper);
  }
  .admin-cat-forum.dragging,
  .admin-cat-group.dragging {
    opacity: 0.72;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }
  .admin-cat-forums.drag-over {
    background: color-mix(in srgb, var(--pink) 6%, var(--card));
  }
  #cat-tree.drag-over-groups {
    outline: 2px dashed var(--pink);
    outline-offset: 4px;
    border-radius: 12px;
  }

  .admin-cat-forum {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 14px 16px;
    border-top: 1px solid var(--hair);
  }
  .admin-cat-forum-main {
    flex: 1;
    min-width: 0;
  }
  .admin-cat-group-title {
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
  }
  .admin-cat-forum p {
    margin: 4px 0 0;
    color: var(--muted);
    font-size: 0.9rem;
  }
  .admin-dialog {
    padding: 0;
    max-width: 420px;
    width: calc(100% - 32px);
  }
  .admin-dialog form {
    padding: 20px;
    display: grid;
    gap: 12px;
  }
  .admin-dialog label {
    display: grid;
    gap: 4px;
    font-size: 0.9rem;
  }

  .access-badge,
  .vis-badge {
    display: inline-block;
    margin-left: 8px;
    padding: 2px 8px;
    border-radius: 999px;
    background: var(--mist);
    font-size: 0.75rem;
    font-weight: 600;
  }
  .vis-badge--listed {
    color: #7c3aed;
    background: #f5f3ff;
  }
  .vis-badge--hidden {
    color: var(--muted);
    background: var(--hair);
  }
  .check-label {
    display: grid;
    gap: 4px;
    font-size: 0.9rem;
  }
  .check-label input {
    width: auto;
    margin-right: 6px;
  }
  .check-hint {
    color: var(--muted);
    font-size: 0.82rem;
    line-height: 1.4;
  }
  .cat-access-fieldset {
    border: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 8px;
  }
  .cat-access-fieldset legend {
    font-size: 0.9rem;
    font-weight: 600;
  }
  .cat-access-levels {
    display: grid;
    gap: 6px;
  }
  .cat-access-option {
    display: flex;
    align-items: center;
    gap: 8px;
  }
</style>