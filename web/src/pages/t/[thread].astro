---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Pagination from '../../components/Pagination.astro';
import Lightbox from '../../components/Lightbox.astro';
import PostEditForm from '../../components/PostEditForm.astro';
import ReplyForm from '../../components/ReplyForm.astro';
import { formatDate } from '../../lib/api';
import { threadJsonLd } from '../../lib/seo';
import {
  getAdminCategories,
  getMe,
  getReportReasons,
  getThread,
  markThreadRead,
  recordThreadView,
  sessionFromCookieHeader,
} from '../../lib/server-api';
import Avatar from '../../components/Avatar.astro';
import PostModGear from '../../components/PostModGear.astro';
import PostReportBtn from '../../components/PostReportBtn.astro';
import ThreadModGear from '../../components/ThreadModGear.astro';
import ThreadReportBtn from '../../components/ThreadReportBtn.astro';
import { ACCENT_CLASSES, PAV_CLASSES, accentIndex } from '../../lib/theme';

const { thread: threadParam } = Astro.params;
const sep = threadParam!.lastIndexOf('--');
if (sep < 0) {
  return Astro.redirect('/community');
}
const id = threadParam!.slice(sep + 2);
const page = Number(Astro.url.searchParams.get('page') ?? '1');
const quoteParam = Astro.url.searchParams.get('quote');
const cookie = Astro.request.headers.get('cookie');
const session = sessionFromCookieHeader(cookie);
const [data, initialUser, reportReasons] = await Promise.all([
  getThread(id, page, session),
  getMe(session),
  getReportReasons(),
]);

if (session) {
  await Promise.all([markThreadRead(session, id), recordThreadView(session, id)]);
}
const user = session ? await getMe(session) : initialUser;

let moveForums: { id: string; name: string }[] = [];
if (session && (initialUser?.is_admin || initialUser?.is_moderator)) {
  try {
    const adminCats = await getAdminCategories(session);
    moveForums = (adminCats.categories ?? [])
      .filter((c) => !c.is_group)
      .map((c) => ({ id: c.id, name: c.name }));
  } catch {
    moveForums = [];
  }
}

let quotePostId: string | null = null;
let quoteAuthor: string | null = null;
let quoteExcerpt: string | null = null;
if (quoteParam) {
  const quoted = data.posts.find((p) => p.id === quoteParam);
  if (quoted) {
    quotePostId = quoted.id;
    quoteAuthor = quoted.author.name;
    quoteExcerpt = quoted.quote?.excerpt ?? quoted.body_html.replace(/<[^>]+>/g, ' ').trim().slice(0, 200);
  }
}

const jsonLd = threadJsonLd(data, data.site.url);
---
<Layout
  title={data.thread.title}
  description={`${data.thread.reply_count} replies in ${data.category.name} — ${data.site.name}`}
  site={data.site}
  user={user}
  jsonLd={jsonLd}
  ogType="article"
  canonical={`${data.site.url.replace(/\/$/, '')}${data.thread.url}`}
  llmDigestUrl={`${data.thread.url}/llm.txt`}
  noIndex={data.ui?.no_index === true}
>
  <div class="crumb">
    <a href="/community">Community</a>
    › <a href={data.category.url}>{data.category.name}</a>
    › {data.thread.title}
  </div>

  <div class="thead">
    <h1>{data.thread.title}</h1>
    {data.thread.summary && (
      <div class="thread-summary">
        <strong>{data.ui?.summary_label ?? 'Summary'}</strong>
        {data.thread.summary}
      </div>
    )}
    <div class="tmeta-row">
      <div
        class="tmeta"
        id="thread-tmeta"
        data-pinned={data.thread.is_pinned ? '1' : '0'}
        data-locked={data.thread.is_locked ? '1' : '0'}
        data-reply-count={data.thread.reply_count}
        data-started={formatDate(data.thread.created_at)}
        data-last-activity={formatDate(data.thread.last_activity_at)}
      >
        {data.thread.reply_count} {data.thread.reply_count === 1 ? 'reply' : 'replies'}
        · started {formatDate(data.thread.created_at)}
        · last activity {formatDate(data.thread.last_activity_at)}
        {data.thread.is_locked && ' · Locked'}
        <span id="thread-lock-reason" class="thread-lock-reason" hidden={!data.thread.lock_reason}>
          {data.thread.lock_reason ? ` — ${data.thread.lock_reason}` : ''}
        </span>
        {data.thread.is_pinned && ' · Pinned'}
        {(data.thread.view_count ?? 0) > 0 && ` · ${data.thread.view_count!.toLocaleString()} views`}
      </div>
      <div class="tmeta-actions">
        {user && (
          <button
            type="button"
            class="btn btn--sm btn--ghost thread-watch-btn"
            id="thread-watch-btn"
            data-thread-id={data.thread.id}
            data-watching={data.thread.email_watching !== false ? '1' : '0'}
          >
            {data.thread.email_watching !== false ? 'Watching' : 'Watch'}
          </button>
        )}
        {user && <ThreadReportBtn threadId={data.thread.id} />}
        {(user?.is_admin || user?.is_moderator) && (
          <ThreadModGear
            threadId={data.thread.id}
            pinned={data.thread.is_pinned}
            locked={data.thread.is_locked}
            reportCount={data.ui?.open_report_count ?? 0}
            moveForums={moveForums}
            currentCategoryId={data.category.id}
          />
        )}
      </div>
    </div>
  </div>

  <div
    id="thread-posts"
    data-thread-id={data.thread.id}
    data-last-page={data.pagination.current >= data.pagination.total ? '1' : '0'}
    data-poll-page={data.pagination.total}
    data-reply-count={data.thread.reply_count}
    data-signed-in={user ? '1' : '0'}
    data-is-staff={(user?.is_admin || user?.is_moderator) ? '1' : '0'}
    data-is-admin={user?.is_admin ? '1' : '0'}
    data-can-perm-ban={user?.can_perm_ban ? '1' : '0'}
    data-report-reasons={JSON.stringify(reportReasons)}
  >
  {data.posts.map((post) => {
    const idx = accentIndex(post.id);
    const excerpt = post.body_html.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim().slice(0, 200);
    return (
      <article class={`post ${ACCENT_CLASSES[idx]}${post.is_accepted_answer ? ' post--accepted' : ''}`} id={`post-${post.id}`}>
        <div class="pside">
          <Avatar
            name={post.author.name}
            avatarUrl={post.author.avatar_url}
            size="post"
            accentClass={PAV_CLASSES[idx]}
            warned={post.author.active_warning}
            title={post.author.active_warning ? 'Active warning' : undefined}
          />
          <div class="pname">
            <a href={post.author.url}>{post.author.name}</a>
          </div>
          {post.author.is_agent && <div class="prole agent-badge">Agent</div>}
          {post.is_op && <div class="prole">Original post</div>}
          {post.is_accepted_answer && <div class="prole prole--accepted">Accepted answer</div>}
          {post.author.karma > 0 && (
            <div class="pkarma">{post.author.karma.toLocaleString()} karma</div>
          )}
        </div>
        <div class="pbody">
          <div class="pdate">
            <div class="pdate-meta">
              <time datetime={post.created_at}>{formatDate(post.created_at)}</time>
              {post.pending_moderation && (
                <span class="post-pending-badge" title="Awaiting moderator approval">Pending approval</span>
              )}
              {post.pending_moderation && (user?.is_admin || user?.is_moderator) && (
                <span class="post-mod-inline">
                  <button type="button" class="btn btn--sm" data-approve-post={post.id}>Approve</button>
                  <button type="button" class="btn btn--sm btn--ghost btn--danger" data-reject-post={post.id}>Reject</button>
                </span>
              )}
              {post.edited_at && (post.can_edit || user?.is_admin) ? (
                <button type="button" class="post-edited-stamp" data-history={post.id} title="View edit history">
                  Edited
                </button>
              ) : post.edited_at ? (
                <span class="post-edited-stamp" title={`Last edited ${formatDate(post.edited_at)}`}>
                  Edited
                </span>
              ) : null}
            </div>
            {user && <PostReportBtn postId={post.id} />}
          </div>
          {post.quote && (
            <a href={post.quote.url} class="post-quote-link" title="Jump to quoted post">
              <blockquote class="post-quote">
                <cite>{post.quote.author_name} wrote:</cite>
                {post.quote.excerpt}
              </blockquote>
            </a>
          )}
          <div class="post-body" data-post-body={post.id} set:html={post.body_html} />
          {post.can_edit && <PostEditForm postId={post.id} />}
          <div class="post-actions">
            {post.can_edit && (
              <button type="button" class="post-action" data-edit={post.id}>
                Edit
              </button>
            )}
            {post.can_delete && (
              <button type="button" class="post-action post-action--danger" data-delete={post.id}>
                Delete
              </button>
            )}
            {user && (
              <button
                type="button"
                class="post-action"
                data-quote={post.id}
                data-quote-author={post.author.name}
                data-quote-excerpt={excerpt}
              >
                Quote
              </button>
            )}
            <button
              type="button"
              class={`post-like ${post.reacted_by_me ? 'is-liked' : ''}`}
              data-post-id={post.id}
              data-liked={post.reacted_by_me ? '1' : '0'}
              disabled={!user}
              title={user ? 'Like this post' : 'Sign in to like'}
            >
              ♥ <span class="like-count">{post.reaction_count}</span>
            </button>
            {(user?.is_admin || user?.is_moderator) && (
              <PostModGear
                postId={post.id}
                threadId={data.thread.id}
                warned={post.is_warned}
                isOP={post.is_op}
                isAccepted={post.is_accepted_answer}
              />
            )}
          </div>
        </div>
      </article>
    );
  })}
  <div id="thread-posts-end"></div>
  </div>

  <Pagination pagination={data.pagination} />

  <ReplyForm
    threadId={data.thread.id}
    threadUrl={data.thread.url}
    signedIn={!!user}
    isAdmin={!!user?.is_admin}
    onLastPage={data.pagination.current >= data.pagination.total}
    locked={data.thread.is_locked}
    quotePostId={quotePostId}
    quoteAuthor={quoteAuthor}
    quoteExcerpt={quoteExcerpt}
  />

  <Lightbox />
</Layout>

{user && (
  <div class="mod-panel" id="mod-panel" hidden>
    <div class="mod-panel-inner mod-panel-inner--wide">
      <button type="button" class="mod-panel-close" id="mod-panel-close" aria-label="Close">×</button>
      <h3 id="mod-panel-title">Details</h3>
      <div class="mod-panel-body" id="mod-panel-body"></div>
    </div>
  </div>
)}

<script>
  import { initModGear } from '../../lib/mod-gear.ts';
  import { initThreadInteractions } from '../../lib/thread-interactions.ts';
  import { initThreadPoll } from '../../lib/thread-poll.ts';

  const modPanel = document.getElementById('mod-panel');
  const modBody = document.getElementById('mod-panel-body');
  const modTitle = document.getElementById('mod-panel-title');
  function openPanel(title, html) {
    if (!modPanel || !modBody) return;
    if (modTitle) modTitle.textContent = title;
    modBody.innerHTML = html;
    modPanel.hidden = false;
  }
  function closeModPanel() {
    if (modPanel) modPanel.hidden = true;
  }
  document.getElementById('mod-panel-close')?.addEventListener('click', (e) => {
    e.preventDefault();
    e.stopPropagation();
    closeModPanel();
  });
  modPanel?.querySelector('.mod-panel-inner')?.addEventListener('click', (e) => {
    e.stopPropagation();
  });
  modPanel?.addEventListener('click', () => closeModPanel());
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modPanel && !modPanel.hidden) closeModPanel();
  });

  initModGear();
  initThreadInteractions(openPanel, closeModPanel);
  initThreadPoll();

  const hash = window.location.hash;
  if (hash) {
    const el = document.querySelector(hash);
    el?.scrollIntoView({ block: 'end', behavior: 'instant' });
  }
</script>