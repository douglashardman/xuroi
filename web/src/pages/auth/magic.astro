---
export const prerender = false;

import { SESSION_COOKIE, SESSION_MAX_AGE, backendFetch } from '../../lib/server-api';

const token = Astro.url.searchParams.get('token')?.trim() ?? '';
if (!token) {
  return Astro.redirect('/join?magic=invalid');
}

const res = await backendFetch(`/v1/auth/magic-link/consume?token=${encodeURIComponent(token)}`);
if (!res.ok) {
  return Astro.redirect('/join?magic=expired');
}

const data = await res.json();
if (data.token) {
  Astro.cookies.set(SESSION_COOKIE, data.token, {
    path: '/',
    httpOnly: true,
    sameSite: 'lax',
    maxAge: SESSION_MAX_AGE,
  });
}

return Astro.redirect('/');
---