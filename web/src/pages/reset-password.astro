---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import { getHome } from '../lib/api';
import { getMe, sessionFromCookieHeader } from '../lib/server-api';

const cookie = Astro.request.headers.get('cookie');
const session = sessionFromCookieHeader(cookie);
const user = await getMe(session);
if (user) {
  return Astro.redirect('/');
}

const token = Astro.url.searchParams.get('token') ?? '';
const data = await getHome();
---
<Layout title="Reset password" site={data.site} user={null}>
  <div class="shead" style="margin-top:40px">
    <h2>Choose a new password</h2>
    <span class="lab">One last step</span>
  </div>

  <section class="auth-card">
    {!token ? (
      <p class="form-error">This reset link is missing or invalid. <a href="/forgot-password">Request a new one</a>.</p>
    ) : (
      <>
        <p>Enter a new password for your account.</p>
        <form id="reset-confirm-form" class="auth-form">
          <input type="hidden" name="token" value={token} />
          <label class="field-label">
            New password
            <input type="password" name="password" id="reset-password" minlength="8" maxlength="128" required autocomplete="new-password" />
            <span class="field-hint" id="reset-password-hint" hidden></span>
          </label>
          <label class="field-label">
            Confirm password
            <input type="password" name="password_confirm" id="reset-password-confirm" minlength="8" maxlength="128" required autocomplete="new-password" />
          </label>
          <button type="submit" class="btn btn--pink">Save password</button>
          <p class="form-error" id="reset-error" hidden></p>
        </form>
      </>
    )}
    <p class="auth-footer"><a href="/join">Back to sign in</a></p>
  </section>
</Layout>

{token && (
  <script>
    import { showToast } from '../lib/toast';
    import { initPasswordStrength, isPasswordAcceptable, wrapPasswordField } from '../lib/join-form';

    const form = document.getElementById('reset-confirm-form') as HTMLFormElement;
    const errorEl = document.getElementById('reset-error') as HTMLElement;
    const pw = document.getElementById('reset-password') as HTMLInputElement;
    const pwHint = document.getElementById('reset-password-hint') as HTMLElement;
    const pwConfirm = document.getElementById('reset-password-confirm') as HTMLInputElement;

    if (pw && pwHint) initPasswordStrength(pw, pwHint);
    if (pw) wrapPasswordField(pw);
    if (pwConfirm) wrapPasswordField(pwConfirm);

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorEl.hidden = true;
      const fd = new FormData(form);
      const token = String(fd.get('token') ?? '');
      const password = String(fd.get('password') ?? '');
      const confirm = String(fd.get('password_confirm') ?? '');
      if (!isPasswordAcceptable(password)) {
        const msg = 'Password must be at least 8 characters';
        errorEl.textContent = msg;
        errorEl.hidden = false;
        showToast(msg, 'error');
        return;
      }
      if (password !== confirm) {
        const msg = 'Passwords do not match';
        errorEl.textContent = msg;
        errorEl.hidden = false;
        showToast(msg, 'error');
        return;
      }
      const res = await fetch('/api/auth/password-reset/confirm', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token, password }),
      });
      const data = await res.json();
      if (!res.ok) {
        const msg = data.error || 'Something went wrong';
        errorEl.textContent = msg;
        errorEl.hidden = false;
        showToast(msg, 'error');
        return;
      }
      showToast('Password updated — welcome back!', 'success');
      window.location.href = '/';
    });
  </script>
)}

<style>
  .auth-card {
    max-width: 480px;
    border: var(--line);
    border-radius: 18px;
    padding: 28px;
    background: var(--card);
    box-shadow: 6px 6px 0 var(--pink);
    margin-bottom: 40px;
  }
  .auth-card p {
    color: var(--muted);
    margin: 0 0 20px;
    font-size: 15px;
  }
  .auth-form {
    display: grid;
    gap: 14px;
  }
  .auth-form label {
    display: grid;
    gap: 6px;
    font-family: Poppins, sans-serif;
    font-weight: 600;
    font-size: 14px;
  }
  .auth-form input {
    border: 2px solid var(--hair);
    border-radius: 10px;
    padding: 10px 12px;
    font: inherit;
    background: var(--paper);
    color: var(--ink);
    width: 100%;
    box-sizing: border-box;
  }
  .auth-form input.field--ok { border-color: #0a7a3e; }
  .auth-form input.field--warn { border-color: #c47d00; }
  .auth-form input.field--error { border-color: var(--pink); }
  .field-hint { font-size: 12px; font-weight: 600; }
  .field-hint--ok { color: #0a7a3e; }
  .field-hint--warn { color: #c47d00; }
  .field-hint--error { color: var(--pink); }
  .password-wrap { position: relative; display: grid; }
  .password-wrap input { padding-right: 4.5rem; }
  .password-reveal {
    position: absolute;
    right: 8px;
    top: 50%;
    transform: translateY(-50%);
    border: 0;
    background: transparent;
    color: var(--pink);
    font-family: Poppins, sans-serif;
    font-size: 12px;
    font-weight: 700;
    cursor: pointer;
    padding: 4px 6px;
  }
  .form-error {
    margin: 0;
    color: var(--pink);
    font-size: 14px;
    font-weight: 600;
  }
  .form-error a {
    color: var(--pink);
  }
  .auth-footer {
    margin: 20px 0 0;
    font-size: 14px;
  }
  .auth-footer a {
    color: var(--pink);
    font-weight: 600;
    text-decoration: none;
  }
</style>