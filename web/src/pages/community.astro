---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import { timeAgo } from '../lib/api';
import { getHome, getMe, sessionFromCookieHeader } from '../lib/server-api';
import { ACCENT_VARS, forumAccentIndex } from '../lib/theme';

const cookie = Astro.request.headers.get('cookie');
const session = sessionFromCookieHeader(cookie);
const [data, user] = await Promise.all([getHome(session), getMe(session)]);
const groups = data.groups ?? [];
const forumCount = (data.categories ?? []).filter((c) => c.can_view).length;
const sectionCount = groups.length;
---
<Layout title="The Community" description={data.site.tagline} site={data.site} user={user} navActive="community">
  <div class="shead" style="margin-top:40px">
    <h2>The Community</h2>
    <span class="lab">{sectionCount} sections · {forumCount} forums</span>
    <a href="/whats-new">
      What's new
      {(user?.unread_threads ?? 0) > 0 && ` (${user!.unread_threads})`}
       →
    </a>
  </div>

  {groups.map((group, gi) => (
    <>
      <div class="cathead">{group.name}</div>
      <div class="flist">
        {group.forums.map((forum, fi) => (
          forum.can_view ? (
            <a class="frow" href={forum.url}>
              <span class="fdot" style={`background:${ACCENT_VARS[forumAccentIndex(gi, fi)]}`}></span>
              <div class="fmain">
                <div class="fname">{forum.name}</div>
                <div class="fdesc">{forum.description}</div>
              </div>
              <div class="fmeta">
                {forum.latest && (
                  <div class="flast">
                    Latest: <b>{forum.latest.title}</b> · by {forum.latest.author_name} · {timeAgo(forum.latest.last_activity_at)}
                  </div>
                )}
                <div class="fstats">
                  <span><b>{forum.thread_count.toLocaleString()}</b> threads</span>
                  <span><b>{forum.post_count.toLocaleString()}</b> messages</span>
                  {(forum.unread_count ?? 0) > 0 && (
                    <span class="funread"><b>{forum.unread_count}</b> unread</span>
                  )}
                </div>
              </div>
            </a>
          ) : (
            <div class="frow frow--locked">
              <span class="fdot fdot--locked"></span>
              <div class="fmain">
                <div class="fname">{forum.name}</div>
                <div class="fdesc">{forum.description}</div>
              </div>
              <div class="flock">
                <span class="lock-badge">{forum.locked_label ?? 'Restricted'}</span>
                {!user && <a href="/join">Sign in</a>}
              </div>
            </div>
          )
        ))}
      </div>
    </>
  ))}
</Layout>

<style>
  .frow--locked {
    cursor: default;
    opacity: 0.92;
  }
  .frow--locked:hover {
    background: var(--card);
  }
  .fdot--locked {
    background: var(--hair) !important;
  }
  .flock {
    min-width: 210px;
    font-size: 13px;
    color: var(--faint);
    text-align: right;
  }
  .lock-badge {
    display: inline-block;
    font-family: Poppins, sans-serif;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 4px;
  }
  .flock a {
    color: var(--pink);
    text-decoration: none;
    font-weight: 600;
  }
  .fmeta {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-left: auto;
    flex-shrink: 0;
    min-width: 0;
  }

  .flast {
    text-align: left;
    min-width: 180px;
    max-width: 320px;
    font-size: 13px;
    color: var(--faint);
    line-height: 1.35;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .flast b {
    font-family: Poppins, sans-serif;
    color: var(--ink);
    font-weight: 600;
  }

  .fstats {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 14px;
    font-family: Poppins, sans-serif;
    font-size: 13px;
    color: var(--faint);
    text-align: right;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .fstats span {
    display: inline;
  }

  .fstats b {
    color: var(--ink);
    font-weight: 700;
  }

  .funread {
    color: var(--pink);
    font-weight: 700;
  }

  @media (max-width: 820px) {
    .flock { display: none; }
    .fmeta { display: none; }
  }
</style>