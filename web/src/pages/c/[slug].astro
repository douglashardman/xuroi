---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Pagination from '../../components/Pagination.astro';
import { formatDate } from '../../lib/api';
import { getCategory, getMe, sessionFromCookieHeader } from '../../lib/server-api';
import { ACCENT_VARS } from '../../lib/theme';

const { slug } = Astro.params;
const page = Number(Astro.url.searchParams.get('page') ?? '1');
const cookie = Astro.request.headers.get('cookie');
const session = sessionFromCookieHeader(cookie);
let data;
try {
  data = await getCategory(slug!, page, session);
} catch (err) {
  const msg = err instanceof Error ? err.message : '';
  if (msg.includes('403')) {
    return Astro.redirect(`/forbidden?forum=${encodeURIComponent(slug!)}`);
  }
  throw err;
}
const user = await getMe(session);
const threads = data.threads ?? [];
---
<Layout title={data.category.name} description={data.category.description} site={data.site} user={user}>
  <div class="crumb">
    <a href="/community">Community</a> › {data.category.name}
  </div>

  <div class="shead" style="margin-top:12px">
    <h2>{data.category.name}</h2>
    <span class="lab">
      {data.category.thread_count} threads
      · <a href={`/c/${slug}/feed.xml`}>RSS</a>
      {(data.category.unread_count ?? 0) > 0 && (
        <> · <span class="unread-lab">{data.category.unread_count} unread</span></>
      )}
    </span>
    {user ? (
      <>
        {(data.category.unread_count ?? 0) > 0 && (
          <button type="button" class="btn btn--sm btn--ghost" id="mark-forum-read" data-slug={slug}>Mark forum read</button>
        )}
        <a href={`/c/${slug}/new`}>New thread →</a>
      </>
    ) : (
      <a href="/community">All forums →</a>
    )}
  </div>

  {data.category.description && (
    <p style="color:var(--muted);margin:0 0 24px;max-width:60ch">{data.category.description}</p>
  )}

  {threads.length === 0 ? (
    <div class="empty-state">No threads yet — be the first to post.</div>
  ) : (
    <div class="threads">
      {threads.map((thread, i) => (
        <a class:list={['thr', thread.is_unread && 'thr--unread']} href={thread.url}>
          <span class:list={['dot', thread.is_unread && 'dot--unread']} style={`background:${ACCENT_VARS[i % 3]}`}></span>
          <div>
            <div class="t">
              {thread.is_unread && <span class="unread-pill">New</span>}
              {thread.title}
              {thread.is_pinned && ' 📌'}
              {thread.is_locked && ' 🔒'}
            </div>
            <div class="sub">by {thread.author_name}</div>
          </div>
          <span class="rep">
            {thread.reply_count} {thread.reply_count === 1 ? 'reply' : 'replies'}
            · {formatDate(thread.last_activity_at)}
          </span>
        </a>
      ))}
    </div>
  )}

  <Pagination pagination={data.pagination} />
</Layout>

{user && (data.category.unread_count ?? 0) > 0 && (
  <script>
    import { showToast } from '../../lib/toast';
    document.getElementById('mark-forum-read')?.addEventListener('click', async () => {
      const btn = document.getElementById('mark-forum-read') as HTMLButtonElement;
      const slug = btn.dataset.slug;
      if (!slug) return;
      btn.disabled = true;
      try {
        const res = await fetch(`/api/categories/${slug}/read`, { method: 'POST' });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Failed');
        showToast('Forum marked read', 'success');
        setTimeout(() => location.reload(), 500);
      } catch (err) {
        showToast(err instanceof Error ? err.message : 'Failed', 'error');
        btn.disabled = false;
      }
    });
  </script>
)}

<style>
  .unread-lab { color: var(--pink); font-weight: 700; }
  .thr--unread .t { font-weight: 800; }
  .dot--unread { box-shadow: 0 0 0 2px var(--pink); }
  .unread-pill {
    display: inline-block;
    margin-right: 6px;
    padding: 1px 6px;
    border-radius: 4px;
    background: var(--pink);
    color: #fff;
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    vertical-align: middle;
  }
</style>