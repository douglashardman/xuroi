---
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import RichTextEditor from '../../../components/RichTextEditor.astro';
import { getCategory, getMe, sessionFromCookieHeader } from '../../../lib/server-api';

const { slug } = Astro.params;
const cookie = Astro.request.headers.get('cookie');
const session = sessionFromCookieHeader(cookie);
const [data, user] = await Promise.all([
  getCategory(slug!, 1, session),
  getMe(session),
]);

if (!user) {
  return Astro.redirect(`/join?next=/c/${slug}/new`);
}
---
<Layout title={`New thread · ${data.category.name}`} site={data.site} user={user}>
  <div class="crumb">
    <a href="/community">Community</a>
    › <a href={data.category.url}>{data.category.name}</a>
    › New thread
  </div>

  <section class="compose-card">
    <h3>Start a discussion</h3>
    <p>Posting in <strong>{data.category.name}</strong>. Select text and use the toolbar to format.</p>
    <form id="new-thread-form" class="compose-form">
      <input type="hidden" name="category_id" value={data.category.id} />
      <label>
        Title
        <input type="text" name="title" required minlength="4" maxlength="200" placeholder="Odyssey vs Scotty on fast greens?" />
      </label>
      <RichTextEditor
        id="thread-body"
        label="Your post"
        placeholder="Share your question or take…"
        size="full"
      />
      <button type="submit" class="btn btn--pink">Post thread</button>
      <p class="form-error" id="thread-error" hidden></p>
    </form>
  </section>
</Layout>

<script>
  import { bindRichTextToolbars, hasEditorContent, prepareEditorMarkdown } from '../../../lib/rich-text-editor.ts';
  bindRichTextToolbars();

  const form = document.getElementById('new-thread-form') as HTMLFormElement | null;
  const categoryId = (form?.querySelector('[name="category_id"]') as HTMLInputElement | null)?.value ?? '';
  const titleInput = form?.querySelector('[name="title"]') as HTMLInputElement | null;
  const editor = document.getElementById('thread-body') as HTMLElement | null;
  const draftKey = `xuroi:draft:new-thread:${categoryId}`;

  if (titleInput && editor) {
    try {
      const saved = JSON.parse(localStorage.getItem(draftKey) ?? 'null') as { title?: string; body?: string } | null;
      if (saved?.title && !titleInput.value) titleInput.value = saved.title;
      if (saved?.body && !hasEditorContent(editor)) editor.innerHTML = saved.body;
    } catch { /* ignore */ }
    let draftTimer: ReturnType<typeof setTimeout> | undefined;
    const saveDraft = () => {
      clearTimeout(draftTimer);
      draftTimer = setTimeout(() => {
        const title = titleInput.value.trim();
        const body = editor.innerHTML;
        if (title || hasEditorContent(editor)) {
          localStorage.setItem(draftKey, JSON.stringify({ title, body }));
        } else {
          localStorage.removeItem(draftKey);
        }
      }, 400);
    };
    titleInput.addEventListener('input', saveDraft);
    editor.addEventListener('input', saveDraft);
  }

  document.getElementById('new-thread-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target;
    const errorEl = document.getElementById('thread-error');
    const btn = form.querySelector('button[type="submit"]');
    const editor = document.getElementById('thread-body');
    errorEl.hidden = true;
    btn.disabled = true;

    if (!editor || !hasEditorContent(editor)) {
      errorEl.textContent = 'Write something first';
      errorEl.hidden = false;
      btn.disabled = false;
      return;
    }

    const fd = new FormData(form);
    const body = Object.fromEntries(fd.entries());
    try {
      body.body_markdown = await prepareEditorMarkdown(editor);
    } catch (err) {
      errorEl.textContent = err instanceof Error ? err.message : 'Image upload failed';
      errorEl.hidden = false;
      btn.disabled = false;
      return;
    }

    try {
      const res = await fetch('/api/threads', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Could not create thread');
      if (data.thread_url) {
        localStorage.removeItem(draftKey);
        window.location.href = data.thread_url;
        return;
      }
      throw new Error('Thread created but no URL returned');
    } catch (err) {
      errorEl.textContent = err instanceof Error ? err.message : 'Could not create thread';
      errorEl.hidden = false;
      btn.disabled = false;
    }
  });
</script>