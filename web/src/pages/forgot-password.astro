---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import { getHome } from '../lib/api';
import { getMe, sessionFromCookieHeader } from '../lib/server-api';

const cookie = Astro.request.headers.get('cookie');
const session = sessionFromCookieHeader(cookie);
const user = await getMe(session);
if (user) {
  return Astro.redirect('/');
}

const data = await getHome();
---
<Layout title="Forgot password" site={data.site} user={null}>
  <div class="shead" style="margin-top:40px">
    <h2>Forgot password</h2>
    <span class="lab">We'll email you a reset link</span>
  </div>

  <section class="auth-card">
    <p>Enter the email on your account. If it's registered, we'll send a link to choose a new password.</p>
    <form id="reset-request-form" class="auth-form">
      <label>
        Email
        <input type="email" name="email" required autocomplete="email" />
      </label>
      <button type="submit" class="btn btn--pink">Send reset link</button>
      <p class="form-error" id="reset-error" hidden></p>
      <p class="form-success" id="reset-success" hidden></p>
    </form>
    <p class="auth-footer"><a href="/join">Back to sign in</a></p>
  </section>
</Layout>

<script>
  import { showToast } from '../lib/toast';

  const form = document.getElementById('reset-request-form') as HTMLFormElement;
  const errorEl = document.getElementById('reset-error') as HTMLElement;
  const successEl = document.getElementById('reset-success') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.hidden = true;
    successEl.hidden = true;
    const fd = new FormData(form);
    const email = String(fd.get('email') ?? '').trim();
    const res = await fetch('/api/auth/password-reset/request', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email }),
    });
    const data = await res.json();
    if (!res.ok) {
      const msg = data.error || 'Something went wrong';
      errorEl.textContent = msg;
      errorEl.hidden = false;
      showToast(msg, 'error');
      return;
    }
    const msg = data.message || 'Check your email for a reset link.';
    successEl.textContent = msg;
    successEl.hidden = false;
    showToast(msg, 'success');
    form.reset();
  });
</script>

<style>
  .auth-card {
    max-width: 480px;
    border: var(--line);
    border-radius: 18px;
    padding: 28px;
    background: var(--card);
    box-shadow: 6px 6px 0 var(--pink);
    margin-bottom: 40px;
  }
  .auth-card p {
    color: var(--muted);
    margin: 0 0 20px;
    font-size: 15px;
  }
  .auth-form {
    display: grid;
    gap: 14px;
  }
  .auth-form label {
    display: grid;
    gap: 6px;
    font-family: Poppins, sans-serif;
    font-weight: 600;
    font-size: 14px;
  }
  .auth-form input {
    border: 2px solid var(--hair);
    border-radius: 10px;
    padding: 10px 12px;
    font: inherit;
    background: var(--paper);
    color: var(--ink);
  }
  .form-error {
    margin: 0;
    color: var(--pink);
    font-size: 14px;
    font-weight: 600;
  }
  .form-success {
    margin: 0;
    color: #0a7a3e;
    font-size: 14px;
    font-weight: 600;
  }
  .auth-footer {
    margin: 20px 0 0;
    font-size: 14px;
  }
  .auth-footer a {
    color: var(--pink);
    font-weight: 600;
    text-decoration: none;
  }
</style>