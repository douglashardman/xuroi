---
interface Props {
  postId: string;
  warned: boolean;
}

const { postId, warned } = Astro.props;
---
<div class="mod-gear-wrap mod-gear-wrap--post">
  <button
    type="button"
    class="mod-gear-btn mod-gear-btn--post"
    data-mod-gear-toggle
    aria-label="Post moderation"
    aria-expanded="false"
    aria-haspopup="true"
  >
    <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="3"/>
      <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
    </svg>
  </button>
  <div class="mod-popover mod-popover--post" data-mod-popover hidden>
    <div class="mod-popover-head">Post</div>
    <button type="button" class="mod-popover-item" data-mod={postId}>
      <span class="mod-popover-label">Audit &amp; ban</span>
    </button>
    <button type="button" class="mod-popover-item" data-warn={postId} disabled={warned}>
      <span class="mod-popover-label">{warned ? 'Already warned' : 'Warn author'}</span>
    </button>
    <button type="button" class="mod-popover-item mod-popover-item--danger" data-remove={postId}>
      <span class="mod-popover-label">Remove post</span>
    </button>
  </div>
</div>