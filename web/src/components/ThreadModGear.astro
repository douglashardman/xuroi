---
interface MoveForum {
  id: string;
  name: string;
}

interface Props {
  threadId: string;
  pinned: boolean;
  locked: boolean;
  reportCount: number;
  moveForums?: MoveForum[];
  currentCategoryId?: string;
}

const { threadId, pinned, locked, reportCount, moveForums = [], currentCategoryId = '' } = Astro.props;
const showBadge = reportCount > 0;
---
<div
  class="mod-gear-wrap mod-gear-wrap--thread"
  data-thread-id={threadId}
  data-current-category={currentCategoryId}
  data-move-forums={JSON.stringify(moveForums)}
>
  <button
    type="button"
    class="mod-gear-btn"
    data-mod-gear-toggle
    aria-label="Moderator tools"
    aria-expanded="false"
    aria-haspopup="true"
  >
    <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="3"/>
      <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
    </svg>
    {showBadge && (
      <span class="mod-gear-badge" data-mod-report-badge>{reportCount > 99 ? '99+' : reportCount}</span>
    )}
    {!showBadge && <span class="mod-gear-badge" data-mod-report-badge hidden></span>}
  </button>

  <div class="mod-popover mod-popover--thread" data-mod-popover hidden>
    <div class="mod-popover-head">Thread</div>
    <button
      type="button"
      class="mod-popover-item"
      data-thread-pin
      data-pinned={pinned ? '1' : '0'}
    >
      <span class="mod-popover-label">{pinned ? 'Unpin thread' : 'Pin thread'}</span>
    </button>
    <button
      type="button"
      class="mod-popover-item"
      data-thread-lock
      data-locked={locked ? '1' : '0'}
    >
      <span class="mod-popover-label">{locked ? 'Unlock thread' : 'Lock thread'}</span>
    </button>

    {moveForums.length > 0 && (
      <>
        <div class="mod-popover-divider"></div>
        <button type="button" class="mod-popover-item" data-thread-move>
          <span class="mod-popover-label">Move thread…</span>
        </button>
      </>
    )}

    <div class="mod-popover-divider"></div>
    <div class="mod-popover-head">Reports</div>
    <button
      type="button"
      class="mod-popover-item"
      data-thread-reports
      data-report-count={reportCount}
    >
      <span class="mod-popover-label">
        {reportCount > 0 ? `Thread reports (${reportCount})` : 'Thread reports'}
      </span>
    </button>
    <a class="mod-popover-item mod-popover-item--link" href="/mod/reports">All reports</a>
    <a class="mod-popover-item mod-popover-item--link" href="/mod/queue">Approval queue</a>

    <div class="mod-popover-divider"></div>
    <button type="button" class="mod-popover-item mod-popover-item--danger" data-thread-delete>
      <span class="mod-popover-label">Delete thread</span>
    </button>
  </div>
</div>