<div class="pt-lightbox" id="pt-lightbox" hidden>
  <div class="pt-lightbox-backdrop"></div>
  <div class="pt-lightbox-panel" role="dialog" aria-modal="true" aria-label="Image viewer">
    <button type="button" class="pt-lightbox-close" aria-label="Close">×</button>
    <button type="button" class="pt-lightbox-prev" aria-label="Previous image">‹</button>
    <button type="button" class="pt-lightbox-next" aria-label="Next image">›</button>
    <img class="pt-lightbox-img" alt="" />
    <div class="pt-lightbox-counter"></div>
  </div>
</div>