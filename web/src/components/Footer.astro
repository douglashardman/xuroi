---
import type { Actor } from '../lib/server-api';

interface Props {
  user?: Actor | null;
}

const { user = null } = Astro.props;
const showReports = user?.is_admin || user?.is_moderator;
---
<footer>
  <div class="wrap">
    <div class="fcols">
      <div class="fbrand">
        <img class="bug" src="/brand/pt-bug.svg" alt="PutterTalk" width="46" height="46" />
        <p>The world's largest destination for putter reviews and discussion. Putter people, since 2006.</p>
        <div class="social">
          <a href="https://instagram.com/puttertalk" aria-label="Instagram @puttertalk">
            <svg viewBox="0 0 24 24"><path d="M12 2.2c3.2 0 3.58.01 4.85.07 3.25.15 4.77 1.69 4.92 4.92.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.15 3.23-1.66 4.77-4.92 4.92-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-3.26-.15-4.77-1.7-4.92-4.92C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85C2.38 3.92 3.9 2.38 7.15 2.27 8.42 2.21 8.8 2.2 12 2.2zm0 1.62c-3.15 0-3.5.01-4.74.07-2.43.11-3.49 1.18-3.6 3.6-.06 1.24-.07 1.59-.07 4.74s.01 3.5.07 4.74c.11 2.42 1.17 3.49 3.6 3.6 1.24.06 1.59.07 4.74.07s3.5-.01 4.74-.07c2.43-.11 3.49-1.18 3.6-3.6.06-1.24.07-1.59.07-4.74s-.01-3.5-.07-4.74c-.11-2.42-1.17-3.49-3.6-3.6-1.24-.06-1.59-.07-4.74-.07zM12 6.86a5.14 5.14 0 100 10.28A5.14 5.14 0 0012 6.86zm0 8.48a3.34 3.34 0 110-6.68 3.34 3.34 0 010 6.68zm5.34-8.69a1.2 1.2 0 100 2.4 1.2 1.2 0 000-2.4z"/></svg>
          </a>
          <a href="https://x.com/puttertalk" aria-label="X @puttertalk">
            <svg viewBox="0 0 24 24"><path d="M18.24 2.25h3.31l-7.23 8.26 8.5 11.24h-6.66l-5.21-6.82-5.97 6.82H1.68l7.73-8.84L1.25 2.25h6.83l4.71 6.23zm-1.16 17.52h1.83L7.08 4.13H5.12z"/></svg>
          </a>
          <a href="https://www.threads.net/@puttertalk" aria-label="Threads @puttertalk">
            <svg viewBox="0 0 24 24"><path d="M12.186 24h-.007c-3.581-.024-6.334-1.205-8.184-3.509C2.35 18.44 1.5 15.586 1.472 12.01v-.017c.03-3.579.879-6.43 2.525-8.482C5.845 1.205 8.6.024 12.18 0h.014c2.746.02 5.043.725 6.826 2.098 1.677 1.29 2.858 3.13 3.509 5.467l-2.04.569c-1.104-3.96-3.898-5.984-8.304-6.015-2.91.022-5.11.936-6.54 2.717C4.307 6.504 3.616 8.914 3.589 12c.027 3.086.718 5.496 2.057 7.164 1.43 1.783 3.631 2.698 6.54 2.717 2.623-.02 4.358-.631 5.8-2.045 1.647-1.613 1.618-3.593 1.09-4.798-.31-.71-.873-1.3-1.634-1.75-.192 1.352-.622 2.446-1.284 3.272-.886 1.102-2.14 1.704-3.73 1.79-1.202.065-2.361-.218-3.259-.801-1.063-.689-1.685-1.74-1.752-2.964-.065-1.19.408-2.285 1.33-3.082.88-.76 2.119-1.207 3.583-1.291a13.853 13.853 0 01 3.02.142c-.126-.742-.375-1.332-.75-1.757-.513-.586-1.308-.883-2.359-.89h-.029c-.844 0-1.992.232-2.721 1.32L7.734 7.847c.98-1.454 2.568-2.256 4.478-2.256h.044c3.194.02 5.097 1.975 5.287 5.388.108.046.216.094.321.142 1.49.7 2.58 1.761 3.154 3.07.797 1.82.871 4.785-1.548 7.155-1.85 1.81-4.094 2.628-7.277 2.65Zm1.504-11.49c-.124 0-.25.004-.377.011-1.834.103-2.974.949-2.91 2.156.062 1.117 1.295 1.637 2.483 1.572 1.092-.058 2.516-.483 2.755-3.345a8.954 8.954 0 01-1.951-.394Z"/></svg>
          </a>
          <a href="https://discord.gg/pPhp65TPsu" aria-label="Discord">
            <svg viewBox="0 0 24 24"><path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189Z"/></svg>
          </a>
        </div>
      </div>
      <div class="fcol">
        <h4>Reviews</h4>
        <a href="#">Latest reviews</a>
        <a href="#">Browse by maker</a>
        <a href="#">The Vault</a>
        <a href="#">Submit a review</a>
      </div>
      <div class="fcol">
        <h4>Community</h4>
        <a href="/community">All forums</a>
        <a href="/search">Search</a>
        <a href="#">What's new</a>
        <a href="#">Members</a>
        <a href="/c/bst">Classifieds</a>
      </div>
      <div class="fcol">
        <h4>Help</h4>
        <a href="#">FAQ</a>
        <a href="#">Community rules</a>
        <a href="mailto:hello@puttertalk.com">Contact</a>
        <a href="#">Report a problem</a>
        {user && (
          <button type="button" class="f-signout" id="footer-logout">Sign out</button>
        )}
      </div>
      {(user?.is_admin || showReports) && (
        <div class="fcol fcol--staff">
          <h4>Staff</h4>
          {user?.is_admin && <a href="/admin">Admin</a>}
          {showReports && <a href="/mod/reports">Reports</a>}
          {showReports && <a href="/mod/queue">Approval queue</a>}
        </div>
      )}
    </div>
    <div class="fbar">
      <span>© 2006–2026 PutterTalk LLC.</span>
      <a href="mailto:hello@puttertalk.com">hello@puttertalk.com</a>
      <span class="powered">Powered by <a href="https://xuroi.com" rel="noopener">Xuroi</a></span>
      <span class="tsw">
        <span class="tlabel">Theme</span>
        <div class="themesw" role="group" aria-label="Color theme">
          <button type="button" data-theme-set="light" title="Light" aria-label="Light theme">
            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="4.2"/><path d="M12 2v2.2M12 19.8V22M2 12h2.2M19.8 12H22M4.6 4.6l1.6 1.6M17.8 17.8l1.6 1.6M19.4 4.6l-1.6 1.6M6.2 17.8l-1.6 1.6"/></svg>
          </button>
          <button type="button" data-theme-set="dark" title="Dark" aria-label="Dark theme">
            <svg viewBox="0 0 24 24"><path d="M21 12.8A8.2 8.2 0 1111.2 3a6.4 6.4 0 009.8 9.8z"/></svg>
          </button>
          <button type="button" data-theme-set="system" title="System" aria-label="Match system">
            <svg viewBox="0 0 24 24"><rect x="3" y="4.5" width="18" height="12.5" rx="2"/><path d="M8.5 20.5h7M12 17v3.5"/></svg>
          </button>
        </div>
      </span>
      <span class="legal">
        <a href="/terms">Terms</a>
        <a href="/privacy">Privacy</a>
        <a href="mailto:hello@puttertalk.com">Contact</a>
      </span>
    </div>
  </div>
</footer>

{user && (
  <script>
    document.getElementById('footer-logout')?.addEventListener('click', async () => {
      await fetch('/api/auth/logout', { method: 'POST' });
      window.location.href = '/';
    });
  </script>
)}