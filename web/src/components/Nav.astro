---
import Avatar from './Avatar.astro';
import type { Actor } from '../lib/server-api';
import { PAV_CLASSES, accentIndex, userURL } from '../lib/theme';

interface Props {
  active?: 'home' | 'community' | 'reviews';
  user?: Actor | null;
  guestCta?: 'join' | 'signin';
}

const { active, user, guestCta = 'join' } = Astro.props;
const navAccent = user ? PAV_CLASSES[accentIndex(user.id)] : '';
---
<nav>
  <div class="wrap nav">
    <a href="/">
      <img class="logo" src="/brand/pt-headline.svg" alt="PutterTalk" width="180" height="32" />
    </a>
    <div class="links">
      <a href="#" class={active === 'reviews' ? 'on' : undefined}>Reviews</a>
      <a href="/community" class={active === 'community' ? 'on' : undefined}>Community</a>
      <a href="#">Brands</a>
      <a href="/c/bst">Classifieds</a>
      <a href="#">The Vault</a>
    </div>
    {user ? (
      <div class="nav-actions">
        <a
          href="/messages"
          class="nav-messages"
          aria-label={(user.unread_dm ?? 0) > 0 ? `${user.unread_dm} unread messages` : 'Messages'}
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
          </svg>
          {(user.unread_dm ?? 0) > 0 && (
            <span class="nav-bell-badge">{user.unread_dm! > 99 ? '99+' : user.unread_dm}</span>
          )}
        </a>
        <a
          href="/notifications"
          class="nav-bell"
          aria-label={user.unread_notifications ? `${user.unread_notifications} unread notifications` : 'Notifications'}
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
            <path d="M13.73 21a2 2 0 0 1-3.46 0" />
          </svg>
          {(user.unread_notifications ?? 0) > 0 && (
            <span class="nav-bell-badge">{user.unread_notifications! > 99 ? '99+' : user.unread_notifications}</span>
          )}
        </a>
        <a href={userURL(user.display_name)} class="nav-account" title={user.display_name}>
          <Avatar
            name={user.display_name}
            avatarUrl={user.avatar_url}
            size="nav"
            accentClass={navAccent}
          />
          <span class="nav-account-name">{user.display_name}</span>
        </a>
        <button type="button" class="nav-signout" id="nav-logout">Sign out</button>
      </div>
    ) : guestCta === 'signin' ? (
      <a class="signin" href="/join">Sign in</a>
    ) : (
      <a class="btn btn--pink btn--sm" href="/join">Join the Community</a>
    )}
  </div>
</nav>

{user && (
  <script>
    document.getElementById('nav-logout')?.addEventListener('click', async () => {
      await fetch('/api/auth/logout', { method: 'POST' });
      window.location.href = '/';
    });
  </script>
)}