---
import Avatar from './Avatar.astro';
import type { Actor } from '../lib/server-api';
import { PAV_CLASSES, accentIndex, userURL } from '../lib/theme';

interface Props {
  active?: 'home' | 'community' | 'reviews';
  user?: Actor | null;
  guestCta?: 'join' | 'signin';
}

const { active, user, guestCta = 'join' } = Astro.props;
const navAccent = user ? PAV_CLASSES[accentIndex(user.id)] : '';
const profileUrl = user ? userURL(user.display_name) : '';
---
<nav>
  <div class="wrap nav">
    <a href="/">
      <img class="logo" src="/brand/pt-headline.svg" alt="PutterTalk" width="180" height="32" />
    </a>
    <div class="links">
      <a href="#" class={active === 'reviews' ? 'on' : undefined}>Reviews</a>
      <a href="/community" class={active === 'community' ? 'on' : undefined}>Community</a>
      <a href="/members">Members</a>
      <a href="#">Brands</a>
      <a href="/c/bst">Classifieds</a>
    </div>
    <div class="nav-actions">
      <a href="/search" class="nav-search" aria-label="Search">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="8" />
          <path d="m21 21-4.35-4.35" />
        </svg>
      </a>
      <div class="nav-online-wrap" id="nav-online-wrap">
        <button
          type="button"
          class="nav-online-btn"
          id="nav-online-btn"
          data-nav-popover-trigger
          aria-expanded="false"
          aria-haspopup="true"
          hidden
        >
          <span class="nav-online-dot" aria-hidden="true"></span>
          <span id="nav-online-count">0</span> online
        </button>
        <div class="nav-online-panel" id="nav-online-panel" data-nav-popover hidden>
          <div class="nav-popover-head">Online now</div>
          <div class="nav-online-list" id="nav-online-list"></div>
        </div>
      </div>
    {user ? (
      <>
        <a
          href="/messages"
          class="nav-messages"
          aria-label={(user.unread_dm ?? 0) > 0 ? `${user.unread_dm} unread messages` : 'Messages'}
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
          </svg>
          {(user.unread_dm ?? 0) > 0 && (
            <span class="nav-bell-badge">{user.unread_dm! > 99 ? '99+' : user.unread_dm}</span>
          )}
        </a>
        <a
          href="/notifications"
          class="nav-bell"
          aria-label={user.unread_notifications ? `${user.unread_notifications} unread notifications` : 'Notifications'}
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
            <path d="M13.73 21a2 2 0 0 1-3.46 0" />
          </svg>
          {(user.unread_notifications ?? 0) > 0 && (
            <span class="nav-bell-badge">{user.unread_notifications! > 99 ? '99+' : user.unread_notifications}</span>
          )}
        </a>
        <div class="nav-user-wrap" id="nav-user-wrap">
          <button
            type="button"
            class="nav-account nav-account-trigger"
            id="nav-user-trigger"
            data-nav-popover-trigger
            aria-expanded="false"
            aria-haspopup="true"
            title={user.display_name}
          >
            <Avatar
              name={user.display_name}
              avatarUrl={user.avatar_url}
              size="nav"
              accentClass={navAccent}
            />
            <span class="nav-account-name">{user.display_name}</span>
          </button>
          <div class="nav-user-menu" id="nav-user-menu" data-nav-popover hidden>
            <a class="nav-user-menu-item" href={profileUrl}>View profile</a>
            <button type="button" class="nav-user-menu-item nav-user-menu-logout" id="nav-logout">Log out</button>
          </div>
        </div>
      </>
    ) : guestCta === 'signin' ? (
      <a class="signin" href="/join">Sign in</a>
    ) : (
      <a class="btn btn--pink btn--sm" href="/join">Join the Community</a>
    )}
    </div>
  </div>
</nav>

<script>
  import { initNavMenus } from '../lib/nav-menu';
  initNavMenus();
</script>