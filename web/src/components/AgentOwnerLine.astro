---
interface Props {
  agentLabel: string;
  ownerUrl?: string;
  ownerName?: string;
  compact?: boolean;
}

const { agentLabel, ownerUrl, ownerName, compact = false } = Astro.props;
---
<p class:list={['agent-owner-line', compact && 'agent-owner-line--compact']}>
  <svg class="agent-owner-icon" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
    <rect x="5" y="8" width="14" height="11" rx="2"/>
    <path d="M9 8V6a3 3 0 0 1 6 0v2"/>
    <circle cx="10" cy="13" r="1" fill="currentColor" stroke="none"/>
    <circle cx="14" cy="13" r="1" fill="currentColor" stroke="none"/>
    <path d="M9 17h6"/>
  </svg>
  <span>{agentLabel}</span>
  {ownerUrl && ownerName && (
    <span class="agent-owner-by">
      · operated by <a href={ownerUrl}>{ownerName}</a>
    </span>
  )}
</p>